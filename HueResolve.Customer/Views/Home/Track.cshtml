@model HueResolve.Models.Model.Report
@{
    ViewData["Title"] = "Tra cứu phản ánh #" + Model.TrackingCode;

    var (statusClass, statusText) = Model.Status switch
    {
        "TiepNhan" => ("bg-info text-dark", "Đã tiếp nhận"),
        "DangXuLy" => ("bg-warning text-dark", "Đang xử lý thực địa"),
        "HoanThanh" => ("bg-success text-white", "Đã hoàn thành"),
        "TuChoi" => ("bg-danger text-white", "Từ chối xử lý"),
        "ChoDuyetKq" => ("bg-info bg-opacity-10 text-info border border-info", "Chờ kết quả"),
        _ => ("bg-secondary text-white", Model.Status)
    };
}

<div class="container py-5">
    <div class="mb-4">
        <a href="@Url.Action("Index", "Home")" class="btn btn-sm btn-outline-secondary fw-bold rounded-pill px-3">
            <i class="fa-solid fa-arrow-left me-2"></i> Về Trang chủ
        </a>
    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-white p-4 border-bottom d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <div class="text-muted small fw-bold text-uppercase mb-1">Kết quả tra cứu mã</div>
                <h4 class="fw-bold text-primary m-0">#@Model.TrackingCode</h4>
            </div>
            <div>
                <span class="badge @statusClass px-3 py-2 rounded-pill fs-6 shadow-sm">
                    @statusText
                </span>
            </div>
        </div>

        <div class="card-body p-4 p-md-5">
            <h3 class="fw-bold mb-3 text-dark">@Model.Title</h3>

            <div class="d-flex flex-wrap gap-4 mb-4 text-muted small border-bottom pb-4">
                <div><i class="fa-regular fa-calendar-check text-primary me-1"></i> <b>Ngày gửi:</b> @Model.CreatedAtUtc.AddHours(7).ToString("dd/MM/yyyy")</div>
                <div><i class="fa-solid fa-location-dot text-danger me-1"></i> <b>Địa chỉ:</b> @Model.AddressText</div>
            </div>

            @{
                var attachments = ViewBag.Attachments as IEnumerable<HueResolve.Models.Model.ReportAttachment>;
                var citizenAttachments = attachments?.Where(a => a.AttachmentType == "Citizen").ToList() ?? new List<HueResolve.Models.Model.ReportAttachment>();
                var resultAttachments = attachments?.Where(a => a.AttachmentType == "Result").ToList() ?? new List<HueResolve.Models.Model.ReportAttachment>();
            }

            <!-- KHU VỰC NỘI DUNG PHẢN ÁNH (BÊN GỬI) -->
            <div class="mb-5">
                <h6 class="fw-bold text-uppercase text-muted mb-3"><i class="fa-solid fa-file-pen me-2"></i>Nội dung phản ánh:</h6>
                <div class="p-4 bg-light rounded-4 text-dark shadow-sm mb-4" style="line-height: 1.8;">
                    @Model.Description
                </div>

                @if (citizenAttachments.Any())
                {
                    <div class="row g-3">
                        @foreach (var img in citizenAttachments)
                        {
                            var base64 = img.FileData != null ? Convert.ToBase64String(img.FileData) : "";
                            var imgSrc = $"data:{img.ContentType};base64,{base64}";
                            bool isVideo = img.ContentType != null && img.ContentType.StartsWith("video/");
                            <div class="col-6 col-md-3">
                                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative" style="cursor: pointer; background: #000;" onclick="openMediaModal('@imgSrc', @(isVideo ? "true" : "false"))">
                                    @if (isVideo)
                                    {
                                        <video src="@imgSrc" class="img-fluid w-100" style="height: 150px; object-fit: cover; pointer-events:none;"></video>
                                        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="background: rgba(0,0,0,0.2);">
                                            <i class="fa-solid fa-play text-white" style="font-size: 2rem; opacity: 0.9;"></i>
                                        </div>
                                    }
                                    else
                                    {
                                        <img src="@imgSrc" alt="Ảnh hiện trường" class="img-fluid w-100" style="height: 150px; object-fit: cover; transition: transform 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- KHU VỰC KẾT QUẢ XỬ LÝ (BÊN NHẬN) -->
            @if (Model.Status == "HoanThanh" || Model.Status == "TuChoi")
            {
                <div class="p-4 p-md-5 rounded-4 border-0 shadow-sm" style="background-color: #f8fafc; border: 1px solid #e2e8f0 !important;">
                    <h5 class="fw-bold text-dark mb-4"><i class="fa-solid fa-square-check text-success me-2"></i>Kết quả xử lý từ cơ quan</h5>

                    @if (!string.IsNullOrEmpty(Model.ResolutionNote))
                    {
                        <div class="mb-4">
                            <div class="p-4 rounded-4 bg-white border-start border-success border-4 shadow-sm">
                                <p class="mb-0 text-dark fw-medium" style="line-height: 1.8;">@Model.ResolutionNote</p>
                                @if (Model.CompletedAtUtc.HasValue)
                                {
                                    <div class="text-muted small mt-3"><i class="fa-regular fa-clock me-1"></i> Hoàn tất lúc: @Model.CompletedAtUtc.Value.AddHours(7).ToString("HH:mm dd/MM/yyyy")</div>
                                }
                            </div>
                        </div>
                    }

                    @if (resultAttachments.Any())
                    {
                        <div class="mb-4">
                            <h6 class="fw-bold text-muted small text-uppercase mb-3">Hình ảnh kết quả thực địa:</h6>
                            <div class="row g-3">
                                @foreach (var img in resultAttachments)
                                {
                                    var base64 = img.FileData != null ? Convert.ToBase64String(img.FileData) : "";
                                    var imgSrc = $"data:{img.ContentType};base64,{base64}";
                                    bool isVideo = img.ContentType != null && img.ContentType.StartsWith("video/");
                                    <div class="col-6 col-md-4 col-lg-3">
                                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative" style="cursor: pointer; background: #000;" onclick="openMediaModal('@imgSrc', @(isVideo ? "true" : "false"))">
                                            @if (isVideo)
                                            {
                                                <video src="@imgSrc" class="img-fluid w-100" style="height: 180px; object-fit: cover; pointer-events:none;"></video>
                                                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="background: rgba(0,0,0,0.2);">
                                                    <i class="fa-solid fa-play text-white" style="font-size: 2rem; opacity: 0.9;"></i>
                                                </div>
                                            }
                                            else
                                            {
                                                <img src="@imgSrc" alt="Ảnh kết quả" class="img-fluid w-100" style="height: 180px; object-fit: cover; transition: transform 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.AdminFeedback))
                    {
                        <div class="mt-4 pt-4 border-top">
                            <h6 class="fw-bold text-primary small text-uppercase mb-2">Phản hồi từ Ban điều hành:</h6>
                            <div class="p-3 rounded-3 bg-white border border-primary border-opacity-10 text-dark italic">
                                "@Model.AdminFeedback"
                            </div>
                        </div>
                    }
                </div>
            }
            else if (Model.Status == "ChoDuyetKq")
            {
                <div class="p-5 text-center bg-light rounded-4 border border-dashed">
                    <div class="mb-3">
                        <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded-pill fw-bold">
                            <i class="fa-solid fa-hourglass-half me-2"></i> Chờ kết quả
                        </span>
                    </div>
                    <i class="fa-solid fa-clipboard-check fs-1 text-info mb-3 opacity-50"></i>
                    <h5 class="fw-bold text-dark">Đã có kết quả xử lý</h5>
                    <p class="text-muted mb-0">Cơ quan chức năng đã báo cáo kết quả. Đang chờ Ban điều hành phê duyệt để gửi tới bạn.</p>
                </div>
            }
            else
            {
                <div class="p-5 text-center bg-light rounded-4 border border-dashed">
                    <i class="fa-solid fa-spinner fa-spin fs-2 text-muted mb-3"></i>
                    <p class="text-muted mb-0">Cơ quan chức năng đang trong quá trình xử lý. Vui lòng quay lại sau.</p>
                </div>
            }
        </div>
    </div>
</div>
<div class="modal fade" id="imageViewerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-transparent border-0 shadow-none">
            <div class="modal-header border-0 pb-0 justify-content-end">
                <button type="button" class="btn-close btn-close-white fs-4" data-bs-dismiss="modal" aria-label="Close" style="filter: invert(1);"></button>
            </div>
            <div class="modal-body text-center pt-0" id="modalMediaContainer">
                <!-- Media will be injected here -->
            </div>
        </div>
    </div>
</div>

<script>
    function openMediaModal(src, isVideo) {
        var container = document.getElementById('modalMediaContainer');
        container.innerHTML = '';
        if (isVideo) {
            container.innerHTML = '<video src="' + src + '" class="img-fluid rounded-4 shadow-lg" controls autoplay style="max-height: 85vh; background: #000;"></video>';
        } else {
            container.innerHTML = '<img src="' + src + '" class="img-fluid rounded-4 shadow-lg" alt="Phóng to ảnh" style="max-height: 85vh;" />';
        }
        var myModal = new bootstrap.Modal(document.getElementById('imageViewerModal'));
        myModal.show();
        
        // Dừng video khi đóng modal
        document.getElementById('imageViewerModal').addEventListener('hidden.bs.modal', function () {
            container.innerHTML = '';
        });
    }
</script>