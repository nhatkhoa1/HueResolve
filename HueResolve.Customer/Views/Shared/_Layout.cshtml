<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HueResolve</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .navbar-brand {
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .nav-link {
            font-weight: 500;
            color: #475569;
            transition: color 0.2s;
        }

            .nav-link:hover, .nav-link.active {
                color: #2563eb;
            }

        .btn-primary {
            background-color: #2563eb;
            border-color: #2563eb;
        }

            .btn-primary:hover {
                background-color: #1d4ed8;
                border-color: #1d4ed8;
            }

        main {
            flex: 1;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top py-3">
        <div class="container">
            <a class="navbar-brand text-primary d-flex align-items-center gap-2" href="@Url.Action("Index", "Home")">
                <i class="fa-solid fa-map-location-dot fs-4"></i>
                <span>HueResolve</span>
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-2">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Home")">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Guide", "Home")">Hướng dẫn</a>
                    </li>
                </ul>

                <div class="d-flex align-items-center gap-3">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a href="@Url.Action("Create", "Report")" class="btn btn-primary fw-bold rounded-pill px-4 shadow-sm">
                            <i class="fa-solid fa-plus me-1"></i> Gửi phản ánh
                        </a>

                        <!-- ═══ CHUÔNG THÔNG BÁO ═══ -->
                        <div class="dropdown" id="notifDropdown">
                            <button class="btn btn-light rounded-circle position-relative shadow-sm border-0"
                                    id="notifBell"
                                    style="width:40px;height:40px;padding:0;"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    onclick="loadNotifications()">
                                <i class="fa-solid fa-bell" style="color:#475569;font-size:1rem;"></i>
                                <span id="notifBadge"
                                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                      style="font-size:.6rem;display:none;min-width:18px;">0</span>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end shadow border-0 p-0"
                                 id="notifPanel"
                                 style="width:340px;border-radius:16px;overflow:hidden;">
                                <!-- Header -->
                                <div class="px-4 py-3 border-bottom d-flex justify-content-between align-items-center"
                                     style="background:#f8fafc;">
                                    <span class="fw-bold" style="font-size:.9rem;color:#1e293b;">
                                        <i class="fa-solid fa-bell me-2 text-primary"></i>Thông báo
                                    </span>
                                    <span id="notifCount" class="badge bg-primary rounded-pill" style="font-size:.7rem;">0</span>
                                </div>
                                <!-- Danh sách thông báo -->
                                <div id="notifList" style="max-height:360px;overflow-y:auto;">
                                    <div class="text-center py-5 text-muted" id="notifEmpty">
                                        <i class="fa-regular fa-bell-slash fa-2x mb-2 d-block opacity-40"></i>
                                        <small>Chưa có thông báo nào</small>
                                    </div>
                                </div>
                                <!-- Footer -->
                                <div class="border-top text-center py-2" style="background:#f8fafc;">
                                    <a href="@Url.Action("MyReports", "Report")" class="text-decoration-none"
                                       style="font-size:.8rem;color:#2563eb;font-weight:600;">
                                        Xem tất cả phản ánh <i class="fa-solid fa-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <!-- ═══ END CHUÔNG ═══ -->

                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle text-dark fw-bold d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                    <i class="fa-solid fa-user"></i>
                                </div>
                                @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" style="border-radius: 12px;">
                                <li><a class="dropdown-item py-2" href="@Url.Action("Profile", "Account")"><i class="fa-solid fa-user me-2 text-muted"></i>Thông tin cá nhân</a></li>
                                <li><a class="dropdown-item py-2" href="@Url.Action("MyReports", "Report")"><i class="fa-solid fa-clock-rotate-left me-2 text-muted"></i>Lịch sử của tôi</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" href="@Url.Action("Logout", "Account")"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary fw-bold rounded-pill px-4">
                            Đăng nhập
                        </a>
                        <a href="@Url.Action("Register", "Account")" class="btn btn-primary fw-bold rounded-pill px-4 shadow-sm">
                            Đăng ký
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="bg-dark text-white pt-5 pb-4 mt-auto">
        <div class="container">
            <div class="row g-4 border-bottom border-secondary pb-4 mb-4">
                <div class="col-lg-4">
                    <h5 class="fw-bold mb-3 d-flex align-items-center gap-2 text-primary">
                        <i class="fa-solid fa-map-location-dot"></i> HueResolve
                    </h5>
                    <p class="text-white-50 small pe-lg-4">
                        Cổng thông tin tiếp nhận và xử lý phản ánh hiện trường trực tuyến, hướng tới mục tiêu xây dựng Thành phố Huế thông minh, xanh - sạch - đẹp.
                    </p>
                </div>
                <div class="col-lg-4">
                    <h6 class="fw-bold mb-3 text-uppercase" style="letter-spacing: 1px;">Liên hệ Trung tâm IOC</h6>
                    <ul class="list-unstyled text-white-50 small">
                        <li class="mb-2"><i class="fa-solid fa-location-dot me-2 text-primary"></i>Tòa nhà Hành chính, TP Huế</li>
                        <li class="mb-2"><i class="fa-solid fa-phone me-2 text-primary"></i>Tổng đài: 1900 1075</li>
                        <li class="mb-2"><i class="fa-solid fa-envelope me-2 text-primary"></i>Email: cskh@hue.gov.vn</li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="fw-bold mb-3 text-uppercase" style="letter-spacing: 1px;">Tải ứng dụng Hue-S</h6>
                    <p class="text-white-50 small">Trải nghiệm tốt hơn trên thiết bị di động của bạn.</p>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-light btn-sm rounded-3"><i class="fa-brands fa-apple me-2"></i>App Store</button>
                        <button class="btn btn-outline-light btn-sm rounded-3"><i class="fa-brands fa-google-play me-2"></i>Google Play</button>
                    </div>
                </div>
            </div>
            <div class="text-center text-white-50 small">
                &copy; @DateTime.Now.Year - Phát triển bởi HueResolve Team. Mọi quyền được bảo lưu.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Tự động đóng các thông báo (Alert) sau 5 giây
        document.addEventListener("DOMContentLoaded", function() {
            setTimeout(function() {
                const alerts = document.querySelectorAll('.alert');
                alerts.forEach(function(alert) {
                    const bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
                    if (bsAlert) bsAlert.close();
                });
            }, 5000);
        });
    </script>
    <script>
        async function loadNotifications() {
            const list = document.getElementById('notifList');
            const empty = document.getElementById('notifEmpty');
            const badge = document.getElementById('notifBadge');
            const count = document.getElementById('notifCount');

            try {
                const response = await fetch('/Account/Notifications');
                const data = await response.json();

                if (data.items && data.items.length > 0) {
                    empty.style.display = 'none';
                    list.innerHTML = data.items.map(item => {
                        let colorClass = "bg-primary";
                        if (item.status === 'HoanThanh') colorClass = "bg-success";
                        if (item.status === 'TuChoi') colorClass = "bg-danger";
                        if (item.status === 'DangXuLy') colorClass = "bg-warning";
                        if (item.status === 'ChoDuyetKq') colorClass = "bg-info";

                        return `
                            <a href="/Home/Track?code=${item.trackingCode}" class="dropdown-item px-4 py-3 border-bottom d-flex align-items-start gap-3" style="white-space: normal;">
                                <div class="rounded-circle ${colorClass} bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                                    <i class="fa-solid ${item.icon} text-${colorClass.replace('bg-', '')}" style="font-size: 1.1rem;"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <span class="fw-bold text-dark" style="font-size:.85rem;">${item.title}</span>
                                        <small class="text-muted" style="font-size:.7rem;">${item.timeAgo}</small>
                                    </div>
                                    <p class="mb-1 text-muted" style="font-size:.8rem; line-height: 1.4;">${item.note || 'Cập nhật trạng thái mới cho phản ánh của bạn'}</p>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge bg-light text-primary border" style="font-size:.65rem;">#${item.trackingCode}</span>
                                        <small class="text-primary fw-bold" style="font-size: .65rem;">Xem chi tiết <i class="fa-solid fa-chevron-right" style="font-size: .5rem;"></i></small>
                                    </div>
                                </div>
                            </a>
                        `;
                    }).join('');
                    
                    count.innerText = data.count;
                    if (data.count > 0) {
                        badge.innerText = data.count;
                        badge.style.display = 'block';
                    } else {
                        badge.style.display = 'none';
                    }
                } else {
                    empty.style.display = 'block';
                    list.innerHTML = '';
                    badge.style.display = 'none';
                    count.innerText = '0';
                }
            } catch (error) {
                console.error('Error loading notifications:', error);
            }
        }

        // Tự động tải thông báo khi trang load
        if (document.getElementById('notifBell')) {
            loadNotifications();
            // Cập nhật mỗi 60 giây
            setInterval(loadNotifications, 60000);
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>