<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HueResolve</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .navbar-brand {
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .nav-link {
            font-weight: 500;
            color: #475569;
            transition: color 0.2s;
        }

            .nav-link:hover, .nav-link.active {
                color: #2563eb;
            }

        .btn-primary {
            background-color: #2563eb;
            border-color: #2563eb;
        }

            .btn-primary:hover {
                background-color: #1d4ed8;
                border-color: #1d4ed8;
            }

        .fab-container {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 1050;
        }

        .fab-button {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background-color: #2563eb;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.4);
            transition: transform 0.2s, background-color 0.2s;
            text-decoration: none;
        }

        .fab-button:hover {
            transform: scale(1.05);
            background-color: #1d4ed8;
            color: white;
        }

        main {
            flex: 1;
        }

        /* Mobile Navbar Fixes */
        .notif-bell-btn {
            width: 40px !important;
            height: 40px !important;
            padding: 0 !important;
            border-radius: 50% !important;
            display: inline-block !important;
            position: relative !important;
            vertical-align: middle;
        }

        .notif-badge {
            position: absolute !important;
            top: 0 !important;
            right: 0 !important;
            transform: translate(25%, -25%) !important;
            font-size: 0.65rem !important;
            padding: 0.35em 0.5em !important;
            border: 2px solid white !important;
            z-index: 10 !important;
        }

        @@media (max-width: 991.98px) {
            .notif-bell-btn {
                width: 100% !important;
                height: 48px !important;
                padding: 0 !important;
                border-radius: 8px !important;
                display: flex !important;
                background-color: transparent !important;
                box-shadow: none !important;
            }
            .notif-bell-btn:hover {
                background-color: #f1f5f9 !important;
            }
            .notif-badge {
                position: static !important;
                transform: none !important;
                margin-left: auto !important;
                border: none !important;
                margin-right: 16px !important;
            }
            .dropdown-menu-mobile {
                position: static !important;
                width: 100% !important;
                max-width: none !important;
                transform: none !important;
                box-shadow: none !important;
                border: 1px solid #e2e8f0 !important;
                margin-top: 8px !important;
                margin-bottom: 8px !important;
            }
            .profile-toggle-btn {
                width: 100%;
                padding: 10px 16px !important;
                border-radius: 8px !important;
            }
            .profile-toggle-btn:hover {
                background-color: #f1f5f9 !important;
            }
            .profile-toggle-btn img, .profile-toggle-btn .bg-primary {
                margin-right: 8px;
            }
        }

        /* Intro Animation (Premium WOW version) */
        .site-intro {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(-45deg, #0f172a, #1e293b, #0ea5e9, #2563eb);
            background-size: 400% 400%;
            animation: gradientBG 4s ease infinite;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.8s cubic-bezier(0.86, 0, 0.07, 1), opacity 0.8s ease;
        }

        .site-intro.fade-out {
            transform: translateY(-100%);
            opacity: 0;
        }

        .intro-glass-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 40px 60px;
            text-align: center;
            color: white;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            animation: card-reveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
            transform: scale(0.9);
            opacity: 0;
            min-width: 320px;
        }

        .intro-icon-wrapper {
            position: relative;
            width: 100px;
            height: 100px;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            perspective: 1000px;
        }

        .intro-logo {
            font-size: 4rem;
            color: #38bdf8;
            z-index: 2;
            animation: icon-flip 1.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
            filter: drop-shadow(0 0 15px rgba(56, 189, 248, 0.6));
        }

        .intro-rings {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: 2px solid rgba(56, 189, 248, 0.3);
            border-radius: 50%;
            animation: ring-pulse 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
        }

        .intro-rings.ring-2 {
            animation-delay: 0.5s;
            border-color: rgba(56, 189, 248, 0.15);
        }

        .intro-title {
            font-weight: 800;
            font-size: 3rem;
            letter-spacing: -1px;
            margin-bottom: 0.5rem;
            opacity: 0;
            animation: text-reveal 1s ease-out 0.5s forwards;
        }

        .text-gradient {
            background: linear-gradient(to right, #38bdf8, #818cf8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .intro-subtitle {
            font-size: 1.1rem;
            color: #94a3b8;
            opacity: 0;
            animation: text-reveal 1s ease-out 0.7s forwards;
            margin-bottom: 30px;
            letter-spacing: 1px;
        }

        .intro-loader-wrapper {
            width: 100%;
            height: 4px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }

        .intro-loader-bar {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #38bdf8, #818cf8);
            border-radius: 4px;
            box-shadow: 0 0 10px rgba(56, 189, 248, 0.5);
            animation: load-progress 2.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }

        body.intro-active {
            overflow: hidden;
        }

        @@keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        @@keyframes card-reveal {
            to { transform: scale(1); opacity: 1; }
        }

        @@keyframes icon-flip {
            0% { transform: rotateY(180deg) scale(0.5); opacity: 0; }
            50% { transform: rotateY(0deg) scale(1.2); opacity: 1; }
            100% { transform: rotateY(0deg) scale(1); opacity: 1; }
        }

        @@keyframes ring-pulse {
            0% { transform: scale(0.8); opacity: 1; }
            100% { transform: scale(1.5); opacity: 0; }
        }

        @@keyframes text-reveal {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        @@keyframes load-progress {
            0% { width: 0%; }
            40% { width: 40%; }
            70% { width: 75%; }
            100% { width: 100%; }
        }
    </style>
</head>
<body>
    <!-- ═══ INTRO SCREEN ═══ -->
    <div id="site-intro" class="site-intro">
        <div class="intro-glass-card">
            <div class="intro-icon-wrapper">
                <i class="fa-solid fa-map-location-dot intro-logo"></i>
                <div class="intro-rings"></div>
                <div class="intro-rings ring-2"></div>
            </div>
            <h1 class="intro-title">
                <span class="text-gradient">Hue</span>Resolve
            </h1>
            <p class="intro-subtitle">Khởi động hệ thống thông minh...</p>
            
            <div class="intro-loader-wrapper">
                <div class="intro-loader-bar"></div>
            </div>
        </div>
    </div>
    <script>
        if (sessionStorage.getItem('introShown')) {
            document.getElementById('site-intro').style.display = 'none';
        } else {
            document.body.classList.add('intro-active');
        }
    </script>
    <!-- ═══ END INTRO ═══ -->

    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top py-3">
        <div class="container">
            <a class="navbar-brand text-primary d-flex align-items-center gap-2" href="@Url.Action("Index", "Home")">
                <i class="fa-solid fa-map-location-dot fs-4"></i>
                <span>HueResolve</span>
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-2">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Home")">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Guide", "Home")">Hướng dẫn</a>
                    </li>
                </ul>

                <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center gap-2 gap-lg-3 mt-3 mt-lg-0">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a href="@Url.Action("Create", "Report")" class="btn btn-primary fw-bold rounded-pill px-4 shadow-sm d-none d-lg-block">
                            <i class="fa-solid fa-plus me-1"></i> Gửi phản ánh
                        </a>

                        <!-- ═══ CHUÔNG THÔNG BÁO ═══ -->
                        <div class="dropdown" id="notifDropdown">
                            <button class="btn btn-light position-relative shadow-sm border-0 notif-bell-btn p-0"
                                    id="notifBell"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    onclick="loadNotifications()">
                                <div class="d-flex align-items-center w-100 h-100 position-relative">
                                    <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 100%;">
                                        <i class="fa-solid fa-bell" style="color:#475569;font-size:1.1rem;"></i>
                                    </div>
                                    <span class="d-lg-none ms-2 fw-medium text-secondary flex-grow-1 text-start">Thông báo</span>
                                    <span id="notifBadge"
                                          class="badge rounded-pill bg-danger notif-badge"
                                          style="display:none;min-width:18px;">0</span>
                                </div>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end shadow border-0 p-0 dropdown-menu-mobile"
                                 id="notifPanel"
                                 style="width:340px;border-radius:16px;overflow:hidden;">
                                <!-- Header -->
                                <div class="px-4 py-3 border-bottom d-flex justify-content-between align-items-center"
                                     style="background:#f8fafc;">
                                    <span class="fw-bold" style="font-size:.9rem;color:#1e293b;">
                                        <i class="fa-solid fa-bell me-2 text-primary"></i>Thông báo
                                    </span>
                                    <span id="notifCount" class="badge bg-primary rounded-pill" style="font-size:.7rem;">0</span>
                                </div>
                                <!-- Danh sách thông báo -->
                                <div id="notifList" style="max-height:360px;overflow-y:auto;">
                                    <div class="text-center py-5 text-muted" id="notifEmpty">
                                        <i class="fa-regular fa-bell-slash fa-2x mb-2 d-block opacity-40"></i>
                                        <small>Chưa có thông báo nào</small>
                                    </div>
                                </div>
                                <!-- Footer -->
                                <div class="border-top text-center py-2" style="background:#f8fafc;">
                                    <a href="@Url.Action("MyReports", "Report")" class="text-decoration-none"
                                       style="font-size:.8rem;color:#2563eb;font-weight:600;">
                                        Xem tất cả phản ánh <i class="fa-solid fa-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <!-- ═══ END CHUÔNG ═══ -->

                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle text-dark fw-bold d-flex align-items-center gap-2 profile-toggle-btn" href="#" role="button" data-bs-toggle="dropdown">
                                @{
                                    var userIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                    string userAvatar = "";
                                    if (Guid.TryParse(userIdStr, out Guid uid))
                                    {
                                        var dbUser = await HueResolve.Business.Services.UserService.GetUserByIdAsync(uid);
                                        userAvatar = dbUser?.AvatarPath ?? "";
                                    }
                                }
                                @if (!string.IsNullOrEmpty(userAvatar))
                                {
                                    <img src="@userAvatar" alt="Avatar" class="rounded-circle object-fit-cover shadow-sm border" style="width: 35px; height: 35px;" />
                                }
                                else
                                {
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                        <i class="fa-solid fa-user"></i>
                                    </div>
                                }
                                @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 dropdown-menu-mobile" style="border-radius: 12px;">
                                <li><a class="dropdown-item py-2" href="@Url.Action("Profile", "Account")"><i class="fa-solid fa-user me-2 text-muted"></i>Thông tin cá nhân</a></li>
                                <li><a class="dropdown-item py-2" href="@Url.Action("MyReports", "Report")"><i class="fa-solid fa-clock-rotate-left me-2 text-muted"></i>Lịch sử của tôi</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" href="@Url.Action("Logout", "Account")"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary fw-bold rounded-pill px-4">
                            Đăng nhập
                        </a>
                        <a href="@Url.Action("Register", "Account")" class="btn btn-primary fw-bold rounded-pill px-4 shadow-sm">
                            Đăng ký
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="bg-dark text-white pt-5 pb-4 mt-auto">
        <div class="container">
            <div class="row g-4 border-bottom border-secondary pb-4 mb-4">
                <div class="col-lg-4">
                    <h5 class="fw-bold mb-3 d-flex align-items-center gap-2 text-primary">
                        <i class="fa-solid fa-map-location-dot"></i> HueResolve
                    </h5>
                    <p class="text-white-50 small pe-lg-4">
                        Cổng thông tin tiếp nhận và xử lý phản ánh hiện trường trực tuyến, hướng tới mục tiêu xây dựng Thành phố Huế thông minh, xanh - sạch - đẹp.
                    </p>
                </div>
                <div class="col-lg-4">
                    <h6 class="fw-bold mb-3 text-uppercase" style="letter-spacing: 1px;">Liên hệ Trung tâm IOC</h6>
                    <ul class="list-unstyled text-white-50 small">
                        <li class="mb-2"><i class="fa-solid fa-location-dot me-2 text-primary"></i>Tòa nhà Hành chính, TP Huế</li>
                        <li class="mb-2"><i class="fa-solid fa-phone me-2 text-primary"></i>Tổng đài: 1900 1075</li>
                        <li class="mb-2"><i class="fa-solid fa-envelope me-2 text-primary"></i>Email: cskh@hue.gov.vn</li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="fw-bold mb-3 text-uppercase" style="letter-spacing: 1px;">Tải ứng dụng Hue-S</h6>
                    <p class="text-white-50 small">Trải nghiệm tốt hơn trên thiết bị di động của bạn.</p>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-light btn-sm rounded-3"><i class="fa-brands fa-apple me-2"></i>App Store</button>
                        <button class="btn btn-outline-light btn-sm rounded-3"><i class="fa-brands fa-google-play me-2"></i>Google Play</button>
                    </div>
                </div>
            </div>
            <div class="text-center text-white-50 small">
                &copy; @DateTime.Now.Year - Phát triển bởi HueResolve Team. Mọi quyền được bảo lưu.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Tự động đóng các thông báo (Alert) sau 5 giây
        document.addEventListener("DOMContentLoaded", function() {
            setTimeout(function() {
                const alerts = document.querySelectorAll('.alert');
                alerts.forEach(function(alert) {
                    const bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
                    if (bsAlert) bsAlert.close();
                });
            }, 5000);

            // Intro logic
            const intro = document.getElementById('site-intro');
            if (intro && !sessionStorage.getItem('introShown')) {
                setTimeout(() => {
                    intro.classList.add('fade-out');
                    document.body.classList.remove('intro-active');
                    sessionStorage.setItem('introShown', 'true');
                    
                    setTimeout(() => {
                        intro.remove();
                    }, 800);
                }, 2800);
            }
        });
    </script>
    <script>
        async function loadNotifications() {
            const list = document.getElementById('notifList');
            const empty = document.getElementById('notifEmpty');
            const badge = document.getElementById('notifBadge');
            const count = document.getElementById('notifCount');

            try {
                const response = await fetch('/Account/Notifications');
                const data = await response.json();

                if (data.items && data.items.length > 0) {
                    empty.style.display = 'none';
                    list.innerHTML = data.items.map(item => {
                        let colorClass = "bg-primary";
                        if (item.status === 'HoanThanh') colorClass = "bg-success";
                        if (item.status === 'TuChoi') colorClass = "bg-danger";
                        if (item.status === 'DangXuLy') colorClass = "bg-warning";
                        if (item.status === 'ChoDuyetKq') colorClass = "bg-info";

                        return `
                            <a href="/Home/Track?code=${item.trackingCode}" class="dropdown-item px-4 py-3 border-bottom d-flex align-items-start gap-3" style="white-space: normal;">
                                <div class="rounded-circle ${colorClass} bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                                    <i class="fa-solid ${item.icon} text-${colorClass.replace('bg-', '')}" style="font-size: 1.1rem;"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <span class="fw-bold text-dark" style="font-size:.85rem;">${item.title}</span>
                                        <small class="text-muted" style="font-size:.7rem;">${item.timeAgo}</small>
                                    </div>
                                    <p class="mb-1 text-muted" style="font-size:.8rem; line-height: 1.4;">${item.note || 'Cập nhật trạng thái mới cho phản ánh của bạn'}</p>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge bg-light text-primary border" style="font-size:.65rem;">#${item.trackingCode}</span>
                                        <small class="text-primary fw-bold" style="font-size: .65rem;">Xem chi tiết <i class="fa-solid fa-chevron-right" style="font-size: .5rem;"></i></small>
                                    </div>
                                </div>
                            </a>
                        `;
                    }).join('');
                    
                    count.innerText = data.count;
                    if (data.count > 0) {
                        badge.innerText = data.count;
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                } else {
                    empty.style.display = 'block';
                    list.innerHTML = '';
                    badge.style.display = 'none';
                    count.innerText = '0';
                }
            } catch (error) {
                console.error('Error loading notifications:', error);
            }
        }

        // Tự động tải thông báo khi trang load
        if (document.getElementById('notifBell')) {
            loadNotifications();
            // Cập nhật mỗi 60 giây
            setInterval(loadNotifications, 60000);
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="fab-container d-lg-none">
            <a href="@Url.Action("Create", "Report")" class="fab-button shadow-lg" title="Gửi phản ánh">
                <i class="fa-solid fa-plus"></i>
            </a>
        </div>
    }
</body>
</html>