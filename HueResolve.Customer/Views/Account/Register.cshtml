@{
    ViewData["Title"] = "Đăng ký tài khoản Công Dân";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-white text-center py-4 border-0">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="fa-solid fa-user-plus fs-3"></i>
                    </div>
                    <h4 class="fw-bold text-dark m-0">Đăng ký Tài khoản mới</h4>
                    <p class="text-muted small mt-1 mb-0">Vui lòng cung cấp thông tin chính xác để IOC tiện liên hệ</p>
                </div>
                <div class="card-body px-4 px-md-5 pb-5 pt-0">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger border-0 small fw-bold shadow-sm rounded-3">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.Error
                        </div>
                    }

                    <form action="@Url.Action("Register", "Account")" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">Tên đăng nhập <span class="text-danger">*</span></label>
                                <input type="text" name="username" class="form-control rounded-3 fs-6" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">Mật khẩu <span class="text-danger">*</span></label>
                                <input type="password" name="password" class="form-control rounded-3 fs-6" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Họ và tên đầy đủ <span class="text-danger">*</span></label>
                            <input type="text" name="fullName" class="form-control rounded-3 fs-6" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Số điện thoại <span class="text-danger">*</span></label>
                            <input type="text" name="phoneNumber" class="form-control rounded-3 fs-6" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase">Địa chỉ thường trú</label>
                            <input type="text" name="addressText" class="form-control rounded-3 fs-6" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm mb-3" style="border-radius: 12px;">
                            <i class="fa-solid fa-check me-2"></i>HOÀN TẤT ĐĂNG KÝ
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <span class="text-muted small">Đã có tài khoản?</span>
                        <a href="@Url.Action("Login", "Account")" class="text-decoration-none fw-bold small ms-1 text-primary">Đăng nhập ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>