@{
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-white text-center py-4 border-0">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="fa-solid fa-user-shield fs-3"></i>
                    </div>
                    <h4 class="fw-bold text-dark m-0">Đăng nhập Cổng Công Dân</h4>
                    <p class="text-muted small mt-1 mb-0">Cùng chung tay xây dựng đô thị thông minh</p>
                </div>
                <div class="card-body px-4 pb-5 pt-0">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger border-0 small fw-bold shadow-sm rounded-3">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.Error
                        </div>
                    }
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success border-0 small fw-bold shadow-sm rounded-3">
                            <i class="fa-solid fa-check-circle me-2"></i> @TempData["Success"]
                        </div>
                    }

                    <form action="@Url.Action("Login", "Account")" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Tên đăng nhập</label>
                            <input type="text" name="username" class="form-control form-control-lg rounded-3 fs-6" placeholder="Nhập tên đăng nhập..." required autofocus />
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase">Mật khẩu</label>
                            <input type="password" name="password" class="form-control form-control-lg rounded-3 fs-6" placeholder="Nhập mật khẩu..." required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm mb-3" style="border-radius: 12px;">
                            ĐĂNG NHẬP NGAY
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <span class="text-muted small">Chưa có tài khoản?</span>
                        <a href="@Url.Action("Register", "Account")" class="text-decoration-none fw-bold small ms-1">Đăng ký tại đây</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>