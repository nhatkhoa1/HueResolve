@model HueResolve.Models.Model.Report
@{
    ViewData["Title"] = "Gửi phản ánh hiện trường mới";
    var categories = ViewBag.Categories as IEnumerable<HueResolve.Models.Model.Category> ?? Enumerable.Empty<HueResolve.Models.Model.Category>();
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header py-4 border-0 text-white" style="background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);">
                    <h4 class="fw-bold m-0"><i class="fa-solid fa-paper-plane me-2"></i> Gửi phản ánh mới</h4>
                    <p class="mb-0 mt-1 small text-white-50">Vui lòng cung cấp thông tin chính xác để cơ quan chức năng xử lý kịp thời.</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger border-0 small fw-bold shadow-sm rounded-3">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.Error
                        </div>
                    }

                    <form action="@Url.Action("Create", "Report")" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <input type="hidden" id="Latitude" name="Latitude" value="" required />
                        <input type="hidden" id="Longitude" name="Longitude" value="" required />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">1. Thông tin chung <span class="text-danger">*</span></label>
                            <input type="text" name="Title" class="form-control form-control-lg rounded-3 mb-3 fs-6" placeholder="Tiêu đề phản ánh" required />

                            <select name="CategoryId" class="form-select form-select-lg rounded-3 mb-3 fs-6">
                                <option value="">-- Không rõ (AI phân loại tự động) --</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>

                            <textarea name="Description" class="form-control rounded-3" rows="4" placeholder="Mô tả chi tiết tình trạng đang diễn ra..." required></textarea>
                        </div>

                        <div class="mb-4 pt-3 border-top">
                            <label class="form-label fw-bold text-dark d-flex justify-content-between align-items-end">
                                <span>2. Vị trí sự cố <span class="text-danger">*</span></span>
                                <button type="button" class="btn btn-sm btn-outline-primary fw-bold" onclick="getLocation()">
                                    <i class="fa-solid fa-location-crosshairs me-1"></i> Lấy vị trí hiện tại
                                </button>
                            </label>

                            <div class="mb-3">
                                <input type="text" id="AddressText" name="AddressText" class="form-control rounded-3" placeholder="Nhập địa chỉ cụ thể..." required />
                            </div>

                            <div class="rounded-3 overflow-hidden border shadow-sm mb-2" style="height: 300px;">
                                <div id="mapPicker" style="height: 100%; width: 100%;"></div>
                            </div>
                            <div class="small text-muted fst-italic"><i class="fa-solid fa-circle-info me-1"></i> Hãy chạm vào bản đồ để ghim chính xác vị trí sự cố.</div>
                        </div>

                        <div class="mb-4 pt-3 border-top">
                            <label class="form-label fw-bold text-dark">3. Ảnh minh chứng <span class="text-danger">*</span></label>
                            <div class="position-relative">
                                <label for="imageInput" class="btn btn-outline-secondary w-100 py-4 rounded-4 border-dashed d-flex flex-column align-items-center justify-content-center gap-2" 
                                       style="border: 2px dashed #e2e8f0; background: #f8fafc; transition: all 0.3s ease;">
                                    <i class="fa-solid fa-cloud-arrow-up fs-2 text-muted"></i>
                                    <span class="fw-bold text-muted">Bấm để chọn ảnh/video hiện trường</span>
                                    <span class="text-muted small">Tối đa 3 ảnh và 1 video. Dung lượng tối đa 5MB/file</span>
                                </label>
                                <input type="file" name="attachmentFiles" id="imageInput" class="position-absolute inset-0 opacity-0 cursor-pointer" 
                                       style="top:0; left:0; width:100%; height:100%; cursor:pointer;"
                                       accept="image/*,video/*" multiple required onchange="previewFiles(event)" />
                            </div>

                            <div class="mt-3 text-center d-none" id="previewContainer" style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;">
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm" style="border-radius: 12px; font-size: 1.1rem;">
                            <i class="fa-solid fa-cloud-arrow-up me-2"></i> GỬI PHẢN ÁNH LÊN HỆ THỐNG
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        var map = L.map('mapPicker').setView([16.4637, 107.5908], 14);
        var marker = null;

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        /* Hàm dịch ngược tọa độ thành tên đường (Reverse Geocoding) */
        function fetchAddress(lat, lng) {
            document.getElementById('AddressText').value = "Đang lấy địa chỉ...";
            fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`)
                .then(response => response.json())
                .then(data => {
                    if(data && data.display_name) {
                        /* Tự động điền vào ô AddressText */
                        document.getElementById('AddressText').value = data.display_name;
                    } else {
                        document.getElementById('AddressText').value = "";
                    }
                })
                .catch(error => {
                    document.getElementById('AddressText').value = "";
                });
        }

        /* Xử lý khi click lên bản đồ */
        map.on('click', function(e) {
            var lat = e.latlng.lat;
            var lng = e.latlng.lng;

            if (marker) map.removeLayer(marker);
            marker = L.marker([lat, lng]).addTo(map);

            document.getElementById('Latitude').value = lat;
            document.getElementById('Longitude').value = lng;

            /* Gọi API lấy tên đường */
            fetchAddress(lat, lng);
        });

        /* Tính năng tự động định vị (GPS) */
        function getLocation() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(function(position) {
                    var lat = position.coords.latitude;
                    var lng = position.coords.longitude;

                    map.setView([lat, lng], 17);

                    if (marker) map.removeLayer(marker);
                    marker = L.marker([lat, lng]).addTo(map);

                    document.getElementById('Latitude').value = lat;
                    document.getElementById('Longitude').value = lng;

                    /* Gọi API lấy tên đường */
                    fetchAddress(lat, lng);
                }, function(error) {
                    alert("Không thể lấy được vị trí của bạn. Vui lòng kiểm tra quyền truy cập vị trí trên trình duyệt.");
                });
            } else {
                alert("Trình duyệt của bạn không hỗ trợ định vị GPS.");
            }
        }

        /* Script hiển thị ảnh Preview và Cộng dồn file */
        var selectedFiles = [];

        function previewFiles(event) {
            var input = event.target;
            
            if (input.files && input.files.length > 0) {
                for (let i = 0; i < input.files.length; i++) {
                    let file = input.files[i];
                    
                    // Kiểm tra dung lượng
                    if (file.size > 5 * 1024 * 1024) {
                        alert(`File ${file.name} vượt quá dung lượng 5MB.`);
                        continue;
                    }

                    // Đếm số lượng hiện tại
                    let imgCount = selectedFiles.filter(f => f.type.startsWith('image/')).length;
                    let vidCount = selectedFiles.filter(f => f.type.startsWith('video/')).length;
                    
                    if (file.type.startsWith('image/') && imgCount >= 3) {
                        alert("Bạn chỉ được chọn tối đa 3 ảnh.");
                        continue;
                    }
                    if (file.type.startsWith('video/') && vidCount >= 1) {
                        alert("Bạn chỉ được chọn tối đa 1 video.");
                        continue;
                    }
                    if (!file.type.startsWith('image/') && !file.type.startsWith('video/')) {
                        alert(`File ${file.name} không đúng định dạng ảnh hoặc video.`);
                        continue;
                    }
                    
                    // Kiểm tra trùng lặp
                    if (!selectedFiles.some(f => f.name === file.name && f.size === file.size)) {
                        selectedFiles.push(file);
                    }
                }
            }
            
            renderPreviews();
            updateInputFiles();
        }

        function removeFile(index) {
            selectedFiles.splice(index, 1);
            renderPreviews();
            updateInputFiles();
        }

        function updateInputFiles() {
            var dataTransfer = new DataTransfer();
            selectedFiles.forEach(f => dataTransfer.items.add(f));
            document.getElementById('imageInput').files = dataTransfer.files;
        }

        function renderPreviews() {
            var container = document.getElementById('previewContainer');
            container.innerHTML = '';
            
            if (selectedFiles.length > 0) {
                container.classList.remove('d-none');
                
                selectedFiles.forEach((file, index) => {
                    let reader = new FileReader();
                    
                    reader.onload = function(e) {
                        let wrapper = document.createElement('div');
                        wrapper.className = 'position-relative shadow-sm rounded-4 overflow-hidden m-2';
                        wrapper.style = 'border: 2px solid var(--bs-primary); background: #000; display: flex; align-items: center; justify-content: center;';

                        // Nút xóa (X)
                        let removeBtn = document.createElement('button');
                        removeBtn.type = 'button';
                        removeBtn.className = 'btn btn-danger btn-sm position-absolute top-0 end-0 m-1 rounded-circle shadow';
                        removeBtn.style = 'width: 24px; height: 24px; padding: 0; z-index: 10; display: flex; align-items: center; justify-content: center;';
                        removeBtn.innerHTML = '<i class="fa-solid fa-times" style="font-size: 12px;"></i>';
                        removeBtn.onclick = function(ev) {
                            ev.preventDefault();
                            removeFile(index);
                        };
                        wrapper.appendChild(removeBtn);

                        if (file.type.startsWith('image/')) {
                            let img = document.createElement('img');
                            img.src = e.target.result;
                            img.style = 'height: 180px; width: auto; max-width: 100%; object-fit: contain;';
                            wrapper.appendChild(img);
                        } else if (file.type.startsWith('video/')) {
                            let vid = document.createElement('video');
                            vid.src = e.target.result;
                            vid.style = 'height: 240px; width: auto; max-width: 100%; object-fit: contain;';
                            vid.controls = true;
                            wrapper.appendChild(vid);
                        }
                        container.appendChild(wrapper);
                    }
                    reader.readAsDataURL(file);
                });
            } else {
                container.classList.add('d-none');
            }
        }
    </script>
}