@model IEnumerable<HueResolve.Models.Model.Report>
@{
    ViewData["Title"] = "Lịch sử phản ánh của tôi";
}

<div class="container py-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h3 class="fw-bold text-dark m-0"><i class="fa-solid fa-clock-rotate-left text-primary me-2"></i> Lịch sử phản ánh</h3>
            <p class="text-muted small mt-1 mb-0">Theo dõi tiến độ các sự cố bạn đã gửi đến hệ thống IOC.</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <a href="@Url.Action("Create", "Report")" class="btn btn-primary fw-bold rounded-pill px-4 shadow-sm">
                <i class="fa-solid fa-plus me-1"></i> Gửi phản ánh mới
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <style>
                    .hover-bg-light:hover { background-color: #f8fafc; }
                    .transition-all { transition: all 0.2s ease; }
                    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
                </style>

                <!-- Desktop Table View -->
                <div class="table-responsive d-none d-lg-block">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="px-4 py-3">Mã tra cứu</th>
                                <th class="py-3">Tiêu đề phản ánh</th>
                                <th class="py-3">Ngày gửi</th>
                                <th class="py-3">Trạng thái</th>
                                <th class="px-4 py-3 text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var (statusClass, statusText) = item.Status switch
                                {
                                    "TiepNhan" => ("bg-info text-dark", "Đã tiếp nhận"),
                                    "DangXuLy" => ("bg-warning text-dark", "Đang xử lý"),
                                    "HoanThanh" => ("bg-success text-white", "Hoàn thành"),
                                    "TuChoi" => ("bg-danger text-white", "Từ chối"),
                                    "ChoDuyetKq" => ("bg-info bg-opacity-10 text-info border border-info", "Chờ kết quả"),
                                    _ => ("bg-secondary text-white", item.Status)
                                };

                                <tr>
                                    <td class="px-4 py-3 fw-bold text-primary">#@item.TrackingCode</td>
                                    <td class="py-3 fw-bold text-dark" style="max-width: 300px;">
                                        <div class="text-truncate" title="@item.Title">@item.Title</div>
                                    </td>
                                    <td class="py-3 text-muted small"><i class="fa-regular fa-clock me-1"></i> @item.CreatedAtUtc.AddHours(7).ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="py-3">
                                        <span class="badge @statusClass rounded-pill">@statusText</span>
                                    </td>
                                    <td class="px-4 py-3 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a href="@Url.Action("Track", "Home", new { code = item.TrackingCode })" class="btn btn-sm btn-outline-primary fw-bold rounded-3">
                                                Xem chi tiết
                                            </a>
                                            @if (!item.AssignedDepartmentId.HasValue)
                                            {
                                                <form asp-controller="Report" asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa phản ánh này không? Hành động này không thể hoàn tác.');" class="m-0">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger fw-bold rounded-3" title="Xóa phản ánh">
                                                        <i class="fa-solid fa-trash-can"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Mobile Card View -->
                <div class="d-lg-none">
                    @foreach (var item in Model)
                    {
                        var (statusClass, statusText) = item.Status switch
                        {
                            "TiepNhan" => ("bg-info text-dark", "Đã tiếp nhận"),
                            "DangXuLy" => ("bg-warning text-dark", "Đang xử lý"),
                            "HoanThanh" => ("bg-success text-white", "Hoàn thành"),
                            "TuChoi" => ("bg-danger text-white", "Từ chối"),
                            "ChoDuyetKq" => ("bg-info bg-opacity-10 text-info border border-info", "Chờ kết quả"),
                            _ => ("bg-secondary text-white", item.Status)
                        };

                        <div class="border-bottom p-3 hover-bg-light transition-all">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge @statusClass rounded-pill">@statusText</span>
                                <span class="text-muted small"><i class="fa-regular fa-clock me-1"></i> @item.CreatedAtUtc.AddHours(7).ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <h6 class="fw-bold text-dark mb-3 line-clamp-2">@item.Title</h6>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-primary fs-6">#@item.TrackingCode</span>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("Track", "Home", new { code = item.TrackingCode })" class="btn btn-sm btn-outline-primary fw-bold rounded-3 px-3">
                                        Chi tiết <i class="fa-solid fa-arrow-right ms-1" style="font-size: 0.8em;"></i>
                                    </a>
                                    @if (!item.AssignedDepartmentId.HasValue)
                                    {
                                        <form asp-controller="Report" asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa phản ánh này không?');" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger fw-bold rounded-3 px-3" title="Xóa">
                                                <i class="fa-solid fa-trash-can"></i> Xóa
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fa-solid fa-folder-open fs-2 text-muted"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Bạn chưa gửi phản ánh nào!</h5>
                    <p class="text-muted small">Những phản ánh bạn gửi sẽ được lưu trữ và theo dõi tại đây.</p>
                </div>
            }
        </div>
    </div>
</div>