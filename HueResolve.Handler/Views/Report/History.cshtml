@model IEnumerable<HueResolve.Models.Model.Report>
@{
    ViewData["Title"] = "Lịch sử xử lý";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string currentSearch = ViewBag.CurrentSearch;
    DateTime? fromDate = ViewBag.FromDate;
    DateTime? toDate = ViewBag.ToDate;
}

<style>
    .filter-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid var(--border-color);
    }
    .table-container {
        background: #ffffff;
        border-radius: 20px;
        border: 1px solid var(--border-color);
        overflow: hidden;
    }
    .btn-details {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 5px 15px;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-main);
        transition: all 0.2s;
    }
    .btn-details:hover {
        background: var(--handler-primary);
        color: #ffffff;
        border-color: var(--handler-primary);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0" style="color: var(--text-main);">Lịch sử xử lý nhiệm vụ</h4>
</div>

<div class="filter-card p-4 mb-4 shadow-sm" style="border-radius: 20px;">
    <form method="get" action="@Url.Action("History")" class="row align-items-center g-3">
        <div class="col-md-3">
            <div class="form-floating">
                <input type="date" name="fromDate" id="fromDate" value="@(fromDate?.ToString("yyyy-MM-dd"))" class="form-control bg-light border-0" style="border-radius: 12px;" />
                <label for="fromDate" class="text-muted fw-bold small"><i class="fa-regular fa-calendar me-1"></i> Từ ngày</label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-floating">
                <input type="date" name="toDate" id="toDate" value="@(toDate?.ToString("yyyy-MM-dd"))" class="form-control bg-light border-0" style="border-radius: 12px;" />
                <label for="toDate" class="text-muted fw-bold small"><i class="fa-regular fa-calendar-check me-1"></i> Đến ngày</label>
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-floating">
                <input type="text" name="search" id="search" value="@currentSearch" class="form-control bg-light border-0" placeholder="Nhập mã, tiêu đề..." style="border-radius: 12px;" />
                <label for="search" class="text-muted fw-bold small"><i class="fa-solid fa-magnifying-glass me-1"></i> Tìm kiếm theo mã, tiêu đề...</label>
            </div>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn text-white fw-bold w-100 shadow-sm" style="background: var(--handler-primary); border-radius: 12px; height: 58px;">
                <i class="fa-solid fa-filter me-1"></i> ÁP DỤNG
            </button>
        </div>
    </form>
</div>

<div class="table-container shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr class="text-muted small text-uppercase fw-bold">
                    <th class="ps-4 py-3 border-0">Mã / Tiêu đề</th>
                    <th class="py-3 border-0">Trạng thái</th>
                    <th class="py-3 border-0">Vị trí thực địa</th>
                    <th class="py-3 border-0">Thời gian nhận</th>
                    <th class="py-3 border-0 text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="fa-solid fa-inbox d-block mb-2 fs-2 text-muted opacity-25"></i>
                            <span class="text-muted small">Chưa có lịch sử xử lý nào.</span>
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold" style="color: var(--handler-primary);">#@item.TrackingCode</div>
                            <div class="text-dark fw-medium text-truncate" style="max-width: 280px;" title="@item.Title">@item.Title</div>
                        </td>
                        <td>
                            @if (item.Status == "HoanThanh")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3"><i class="fa-solid fa-check me-1"></i>Hoàn thành</span>
                            }
                            else if (item.Status == "TuChoi")
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3"><i class="fa-solid fa-xmark me-1"></i>Từ chối</span>
                            }
                        </td>
                        <td>
                            <div class="small text-muted text-truncate" style="max-width: 200px;">
                                <i class="fa-solid fa-location-dot me-1 text-danger"></i> @item.AddressText
                            </div>
                        </td>
                        <td class="small text-dark">
                            @item.CreatedAtUtc.AddHours(7).ToString("dd/MM/yyyy")<br />
                            <span class="text-muted" style="font-size: 0.7rem;">@item.CreatedAtUtc.AddHours(7).ToString("HH:mm")</span>
                        </td>
                        <td class="text-end pe-4">
                            <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-details">
                                XEM LẠI
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="p-3 border-top bg-white d-flex justify-content-center">
            <nav>
                <ul class="pagination pagination-sm m-0">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link border-0 mx-1 rounded-3 @(i == currentPage ? "text-white shadow-sm" : "text-dark fw-bold")"
                               style="@(i == currentPage ? "background: var(--handler-primary);" : "")"
                               href="@Url.Action("History", new { page = i, fromDate = fromDate?.ToString("yyyy-MM-dd"), toDate = toDate?.ToString("yyyy-MM-dd"), search = currentSearch })">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
