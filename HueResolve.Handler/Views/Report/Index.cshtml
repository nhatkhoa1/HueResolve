@model IEnumerable<HueResolve.Models.Model.Report>
@{
    ViewData["Title"] = "Danh sách nhiệm vụ";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string currentStatus = ViewBag.CurrentStatus ?? "DangXuLy";
}

<style>
    .filter-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid var(--border-color);
    }

    .table-container {
        background: #ffffff;
        border-radius: 20px;
        border: 1px solid var(--border-color);
        overflow: hidden;
    }

    .status-tab {
        padding: 8px 20px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.85rem;
        text-decoration: none;
        transition: all 0.2s;
        color: var(--text-muted);
        border: 1px solid transparent;
    }

        .status-tab:hover {
            background: #f1f5f9;
            color: var(--handler-indigo);
        }

        .status-tab.active {
            background: #eef2ff;
            color: var(--handler-indigo);
            border-color: #c7d2fe;
        }

    .btn-details {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 5px 15px;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-main);
        transition: all 0.2s;
    }

        .btn-details:hover {
            background: var(--handler-indigo);
            color: #ffffff;
            border-color: var(--handler-indigo);
        }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0" style="color: var(--text-main);">Quản lý Nhiệm vụ được giao</h4>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Index", "Report", new { status = "DangXuLy" })"
           class="status-tab @(currentStatus == "DangXuLy" ? "active" : "")">Đang thực hiện</a>
        <a href="@Url.Action("Index", "Report", new { status = "ChoDuyetKq" })"
           class="status-tab @(currentStatus == "ChoDuyetKq" ? "active" : "")">Chờ kết quả duyệt</a>
        <a href="@Url.Action("Index", "Report", new { status = "HoanThanh" })"
           class="status-tab @(currentStatus == "HoanThanh" ? "active" : "")">Đã hoàn thành</a>
        <a href="@Url.Action("Index", "Report", new { status = "TuChoi" })"
           class="status-tab @(currentStatus == "TuChoi" ? "active" : "")">Từ chối</a>
    </div>
</div>

<div class="filter-card p-3 mb-4 shadow-sm">
    <form method="get" action="@Url.Action("Index")" class="row g-2">
        <input type="hidden" name="status" value="@currentStatus" />

        <div class="col-md-10">
            <div class="input-group input-group-sm h-100">
                <span class="input-group-text bg-light border-0 px-3"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                <input type="text" name="search" value="@ViewBag.CurrentSearch" class="form-control bg-light border-0 py-2" placeholder="Nhập mã phản ánh (VD: HUE-...) hoặc tiêu đề sự cố để tìm kiếm..." />
            </div>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-sm w-100 text-white fw-bold h-100 shadow-sm" style="background: var(--handler-indigo); border-radius: 8px;">
                TÌM KIẾM
            </button>
        </div>
    </form>
</div>

<div class="table-container shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr class="text-muted small text-uppercase fw-bold">
                    <th class="ps-4 py-3 border-0">Mã / Thông tin sự cố</th>
                    <th class="py-3 border-0">Lĩnh vực</th>
                    <th class="py-3 border-0">Vị trí thực địa</th>
                    <th class="py-3 border-0">Thời gian nhận</th>
                    <th class="py-3 border-0 text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="fa-solid fa-inbox d-block mb-2 fs-2 text-muted opacity-25"></i>
                            <span class="text-muted small">Không tìm thấy nhiệm vụ nào phù hợp.</span>
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold" style="color: var(--handler-indigo);">#@item.TrackingCode</div>
                            <div class="text-dark fw-medium text-truncate" style="max-width: 280px;" title="@item.Title">@item.Title</div>
                            @if (item.Status == "DangXuLy" && (DateTime.UtcNow - item.CreatedAtUtc).TotalDays > 5)
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger small mt-1" style="font-size: 0.65rem;">
                                    <i class="fa-solid fa-clock me-1"></i> QUÁ HẠN XỬ LÝ
                                </span>
                            }
                        </td>
                        <td>
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3">
                                @item.CategoryId
                            </span>
                        </td>
                        <td>
                            <div class="small text-muted text-truncate" style="max-width: 200px;">
                                <i class="fa-solid fa-location-dot me-1 text-danger"></i> @item.AddressText
                            </div>
                        </td>
                        <td class="small text-dark">
                            @item.CreatedAtUtc.AddHours(7).ToString("dd/MM/yyyy")<br />
                            <span class="text-muted" style="font-size: 0.7rem;">@item.CreatedAtUtc.AddHours(7).ToString("HH:mm")</span>
                        </td>
                        <td class="text-end pe-4">
                            <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-details">
                                CHI TIẾT
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="p-3 border-top bg-white d-flex justify-content-center">
            <nav>
                <ul class="pagination pagination-sm m-0">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link border-0 mx-1 rounded-3 @(i == currentPage ? "text-white shadow-sm" : "text-dark fw-bold")"
                               style="@(i == currentPage ? "background: var(--handler-indigo);" : "")"
                               href="@Url.Action("Index", new { page = i, status = currentStatus, search = ViewBag.CurrentSearch, categoryId = ViewBag.CurrentCategory })">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>