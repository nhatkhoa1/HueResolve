@model HueResolve.Models.Model.Report
@{
    ViewData["Title"] = "Chi tiết nhiệm vụ xử lý";
    var attachments = ViewBag.Attachments as IEnumerable<HueResolve.Models.Model.ReportAttachment> ?? Enumerable.Empty<HueResolve.Models.Model.ReportAttachment>();
    var citizenAttachments = attachments.Where(a => a.AttachmentType == "Citizen").ToList();
    var resultAttachments = attachments.Where(a => a.AttachmentType == "Result").ToList();

    // Kiểm tra xem phản ánh còn trong luồng cho phép xử lý hay không
    bool isEditable = Model.Status == "DangXuLy";
}

<style>
    .info-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #94a3b8;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .content-box {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    .status-banner {
        border-radius: 12px;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
    }

    .img-grid-item {
        width: 100%;
        height: 120px;
        object-fit: cover; /* 🔥 crop ảnh */
        border-radius: 10px;
    }

        .img-grid-item:hover {
            transform: scale(1.03);
        }

    .btn-delete-img {
        position: absolute;
        top: -5px;
        right: -5px;
        width: 24px;
        height: 24px;
        padding: 0;
        border-radius: 50%;
        z-index: 5;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }
</style>

<div class="mb-4">
    <a href="@Url.Action("Index", "Report")" class="text-decoration-none fw-medium small text-muted">
        <i class="fa-solid fa-arrow-left me-1"></i> Quay lại danh sách
    </a>
</div>

<div class="status-banner shadow-sm @(Model.Status == "HoanThanh" ? "bg-success text-white" : (Model.Status == "TuChoi" ? "bg-danger text-white" : "bg-white border"))">
    <div>
        <div class="@(isEditable ? "text-muted" : "text-white-50") small fw-bold">MÃ PHẢN ÁNH</div>
        <h4 class="fw-bold m-0">#@Model.TrackingCode</h4>
    </div>
    <div class="text-end">
        <div class="@(isEditable ? "text-muted" : "text-white-50") small fw-bold text-uppercase">TRẠNG THÁI HIỆN TẠI</div>
        <span class="badge @(isEditable ? "bg-warning text-warning bg-opacity-10 border border-warning" : "bg-white text-dark") rounded-pill px-3 py-2 fw-bold">
            @switch (Model.Status)
            {
                case "DangXuLy":
                    <text><i class="fa-solid fa-person-digging me-1"></i> ĐANG THỰC ĐỊA</text>
                    ;
                    break;
                case "HoanThanh":
                    <text><i class="fa-solid fa-circle-check me-1"></i> ĐÃ HOÀN THÀNH</text>
                    ;
                    break;
                case "TuChoi":
                    <text><i class="fa-solid fa-circle-xmark me-1"></i> ĐÃ TỪ CHỐI</text>
                    ;
                    break;
                default:
                    @Model.Status
                    ;
                    break;
            }
        </span>
    </div>
</div>

<div class="content-box p-4 shadow-sm">
    <h6 class="fw-bold mb-3 text-dark">
        <i class="fa-solid fa-camera text-muted me-2"></i>ẢNH MINH CHỨNG HIỆN TRƯỜNG
    </h6>

    @* ✅ FORM UPLOAD ĐÃ ĐƯỢC ĐƯA LÊN TRÊN *@
    @if (isEditable)
    {
        <form action="@Url.Action("UploadAttachment", "Report")" method="post" enctype="multipart/form-data" class="mb-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="reportId" value="@Model.Id" />
            <div class="position-relative">
                <label for="fileInput" class="btn btn-outline-secondary w-100 py-3 rounded-4 border-dashed d-flex flex-column align-items-center justify-content-center gap-2" 
                       style="border: 2px dashed #e2e8f0; background: #f8fafc; transition: all 0.3s ease;">
                    <i class="fa-solid fa-images fs-3 text-muted"></i>
                    <span class="fw-bold text-muted small">Bấm để chọn hoặc kéo thả ảnh minh chứng vào đây</span>
                    <span class="text-muted" style="font-size: 0.7rem;">(Tự động tải lên sau khi chọn)</span>
                </label>
                <input type="file" name="file" id="fileInput" class="position-absolute inset-0 opacity-0 cursor-pointer" 
                       style="top:0; left:0; width:100%; height:100%; cursor:pointer;"
                       accept="image/*" required onchange="this.form.submit()" />
            </div>
        </form>
    }

    <div class="row g-2 mb-4">
        <h6 class="w-100 fw-bold mt-2 mb-2 text-dark" style="font-size:0.85rem">Ảnh từ người dân</h6>
        @if (citizenAttachments.Any())
        {
            @foreach (var img in citizenAttachments)
            {
                string imageBase64 = "";
                if (img.FileData != null)
                {
                    imageBase64 = $"data:{img.ContentType};base64,{Convert.ToBase64String(img.FileData)}";
                }

                <div class="col-4 position-relative">
                    <img src="@imageBase64" class="img-grid-item shadow-sm"
                         onclick="viewImageModal('@imageBase64')" alt="Minh chứng từ người dân" />
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="p-3 bg-light rounded-3 text-center border border-dashed text-muted small">
                    Chưa có hình ảnh minh chứng từ người dân.
                </div>
            </div>
        }
    </div>

    <div class="row g-2 mb-2">
        <h6 class="w-100 fw-bold mb-2 text-dark" style="font-size:0.85rem">Ảnh kết quả xử lý (Của bạn)</h6>
        @if (resultAttachments.Any())
        {
            @foreach (var img in resultAttachments)
            {
                string imageBase64 = "";
                if (img.FileData != null)
                {
                    imageBase64 = $"data:{img.ContentType};base64,{Convert.ToBase64String(img.FileData)}";
                }

                <div class="col-4 position-relative">
                    <img src="@imageBase64" class="img-grid-item shadow-sm"
                         onclick="viewImageModal('@imageBase64')" alt="Minh chứng kết quả xử lý" />
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="p-3 bg-light rounded-3 text-center border border-dashed text-muted small">
                    Chưa có ảnh kết quả xử lý.
                </div>
            </div>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="content-box p-4 p-xl-5 shadow-sm">
            <h5 class="fw-bold mb-4 text-dark border-bottom pb-3">Thông tin hiện trường</h5>

            <div class="mb-4">
                <div class="info-label">Tiêu đề</div>
                <div class="fw-bold fs-5 text-dark">@Model.Title</div>
            </div>

            <div class="mb-4">
                <div class="info-label">Nội dung mô tả từ người dân</div>
                <div class="p-3 bg-light rounded-3 border text-dark shadow-sm">@Model.Description</div>
            </div>

            <div class="row mb-4">
                <div class="col-md-7">
                    <div class="info-label">Địa chỉ</div>
                    <div class="text-dark fw-medium"><i class="fa-solid fa-location-dot text-danger me-1"></i> @Model.AddressText</div>
                </div>
                <div class="col-md-5 text-md-end">
                    <div class="info-label">Thời gian gửi</div>
                    <div class="text-dark small"><i class="fa-solid fa-clock text-primary me-1"></i> @Model.CreatedAtUtc.AddHours(7).ToString("dd/MM/yyyy HH:mm")</div>
                </div>
            </div>

            @if (Model.Latitude != 0 && Model.Longitude != 0)
            {
                <div class="mt-4 pt-3 border-top">
                    <a href="https://www.google.com/maps/search/?api=1&query=@Model.Latitude,@Model.Longitude"
                       target="_blank" class="btn btn-sm btn-outline-primary rounded-3 px-3 fw-bold">
                        <i class="fa-solid fa-map-location-dot me-2"></i> MỞ BẢN ĐỒ CHỈ ĐƯỜNG
                    </a>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-5">

        <div class="content-box p-4 mb-4 shadow-sm border-top border-2 @(isEditable ? "border-primary" : "border-success")">
            <h6 class="fw-bold mb-4 @(isEditable ? "text-primary" : "text-success")">
                <i class="fa-solid fa-clipboard-check me-2"></i>BÁO CÁO KẾT QUẢ XỬ LÝ
            </h6>

            @if (isEditable)
            {
                <form action="@Url.Action("SubmitResult", "Report")" method="post" id="submitResultForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="reportId" value="@Model.Id" />

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-dark">Chi tiết công việc đã thực hiện <span class="text-danger">*</span></label>
                        <textarea name="resolutionNote" class="form-control rounded-3" rows="5" required
                              placeholder="Ghi rõ các biện pháp đã khắc phục tại hiện trường..."></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" name="resultStatus" value="HoanThanh" class="btn btn-success flex-fill py-3 fw-bold shadow-sm" style="border-radius: 12px;">
                            ĐỀ XUẤT HOÀN THÀNH
                        </button>
                        <button type="submit" name="resultStatus" value="TuChoi" class="btn btn-danger flex-fill py-3 fw-bold shadow-sm" style="border-radius: 12px;">
                            ĐỀ XUẤT TỪ CHỐI
                        </button>
                    </div>
                </form>
            }
            @if (!isEditable)
            {
                <div class="p-3 bg-light rounded-3 border border-dashed mb-2">
                    <div class="info-label">Nội dung báo cáo kết quả:</div>
                    <div class="text-dark fw-bold italic">"@Model.ResolutionNote"</div>
                </div>
                <div class="alert alert-info border-0 small m-0 mt-3">
                    <i class="fa-solid fa-lock me-2"></i>@(Model.Status == "ChoDuyetKq" ? "Đã gửi yêu cầu duyệt kết quả lên cấp trên. Vui lòng chờ phản hồi." : "Nhiệm vụ này đã được chốt kết quả và không thể chỉnh sửa thêm.")
                </div>
            }
            
            @if (!string.IsNullOrEmpty(Model.AdminFeedback))
            {
                <div class="mt-4 p-3 rounded-4 border-start border-4 border-info" style="background: #f0f9ff;">
                    <div class="info-label text-info"><i class="fa-solid fa-comment-dots me-1"></i> Phản hồi từ Ban điều hành:</div>
                    <div class="text-dark fw-bold">@Model.AdminFeedback</div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="imageLightbox" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-header border-0 p-0 mb-2 justify-content-end">
                <button type="button" class="btn btn-light rounded-circle" data-bs-dismiss="modal">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body p-0 text-center">
                <img id="modalImg" src="" class="img-fluid rounded-4 shadow-lg" style="max-height: 85vh; border: 5px solid white;" />
            </div>
        </div>
    </div>
</div>

<script>
    function viewImageModal(src) {
        document.getElementById('modalImg').src = src;
        var myModal = new bootstrap.Modal(document.getElementById('imageLightbox'));
        myModal.show();
    }
</script>

<!-- Modal Thông báo Thành công -->
<div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body text-center p-5">
                <div class="mb-4">
                    <i class="fa-solid fa-circle-check text-success" style="font-size: 4rem;"></i>
                </div>
                <h5 class="fw-bold mb-3">Thành công!</h5>
                <p class="text-muted mb-4">@TempData["Success"]</p>
                <button type="button" class="btn btn-success w-100 rounded-3 fw-bold py-2" data-bs-dismiss="modal">ĐÓNG</button>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var successModal = new bootstrap.Modal(document.getElementById('successModal'));
            successModal.show();
        });
    </script>
}