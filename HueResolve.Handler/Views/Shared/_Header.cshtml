<style>
    .main-header {
        height: var(--header-height);
        background: #ffffff;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2rem;
        position: sticky;
        top: 0;
        z-index: 999;
    }
</style>

<header class="main-header">
    <div class="d-flex align-items-center">
        <button class="btn btn-light border-0 rounded-circle me-3" id="menu-toggle">
            <i class="fa-solid fa-bars-staggered"></i>
        </button>
        <div class="fw-bold text-secondary" style="color: var(--text-main) !important;">
            @DateTime.Now.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"))
        </div>
    </div>

    <div class="d-flex align-items-center gap-3">
        <div class="dropdown">
            <button class="btn btn-light border-0 rounded-circle position-relative p-2" data-bs-toggle="dropdown" style="background: #f4f7fe; color: var(--handler-primary);" onclick="loadHandlerNotifications()">
                <i class="fa-solid fa-bell fs-5"></i>
                <span id="handlerNotifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white" style="font-size: 0.65rem; display: none;">
                    0
                </span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-4 p-2 mt-3" style="width: 320px;">
                <li class="dropdown-header fw-bold d-flex justify-content-between align-items-center">
                    <span>Thông báo mới</span>
                    <span class="badge bg-primary rounded-pill" id="handlerNotifCount">0</span>
                </li>
                <li><hr class="dropdown-divider"></li>
                <div id="handlerNotifList">
                    <!-- Notifications will be loaded here -->
                </div>
                <li id="handlerNotifEmpty" class="text-center p-3 text-muted">
                    <i class="fa-regular fa-bell-slash fs-4 mb-2"></i>
                    <div class="small">Đang tải thông báo...</div>
                </li>
            </ul>
        </div>

        <div class="vr mx-2 text-muted opacity-25"></div>

        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            <button type="submit" class="btn btn-link text-decoration-none text-danger fw-bold small p-0">
                ĐĂNG XUẤT <i class="fa-solid fa-right-from-bracket ms-2"></i>
            </button>
        </form>
    </div>
</header>