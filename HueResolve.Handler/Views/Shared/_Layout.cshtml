<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HueResolve Handler</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --sidebar-width: 280px;
            --header-height: 80px;
            --handler-bg: #f4f7fe;
            --handler-primary: #4318FF; /* Vibrant Modern Blue */
            --handler-primary-hover: #3311DB;
            --handler-indigo: #4318FF; /* Keep for backwards compatibility */
            --text-main: #2B3674;
            --text-muted: #A3AED0;
            --border-color: #E9EDF7;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--handler-bg);
            color: var(--text-main);
            overflow-x: hidden;
        }

        #wrapper { display: flex; }

        /* Content Area */
        #page-content-wrapper {
            width: 100%;
            min-height: 100vh;
            margin-left: var(--sidebar-width);
            transition: all 0.3s;
        }

        .main-content {
            padding: 2rem;
            min-height: calc(100vh - var(--header-height) - 60px);
        }

        /* Responsive */
        @@media (max-width: 992px) {
            #page-content-wrapper { margin-left: 0; }
            #sidebar-wrapper { margin-left: calc(-1 * var(--sidebar-width)); }
            #wrapper.toggled #sidebar-wrapper { margin-left: 0; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="wrapper">
        @await Html.PartialAsync("_Sidebar")

        <div id="page-content-wrapper">
            @await Html.PartialAsync("_Header")

            <main class="main-content">
                @RenderBody()
            </main>

            @await Html.PartialAsync("_Footer")
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $("#menu-toggle").click(function(e) {
            e.preventDefault();
            $("#wrapper").toggleClass("toggled");
        });

        async function loadHandlerNotifications() {
            try {
                const response = await fetch('/Dashboard/GetNotifications');
                if (!response.ok) return;
                const data = await response.json();
                
                const badge = document.getElementById('handlerNotifBadge');
                const count = document.getElementById('handlerNotifCount');
                const list = document.getElementById('handlerNotifList');
                const empty = document.getElementById('handlerNotifEmpty');

                if (count) count.innerText = data.count;
                
                if (data.count > 0) {
                    if (badge) {
                        badge.innerText = data.count;
                        badge.style.display = 'inline-block';
                    }
                    if (empty) empty.style.display = 'none';
                    if (list) {
                        list.innerHTML = data.items.map(item => `
                            <li>
                                <a class="dropdown-item rounded-3 py-2 px-3 small border-bottom" href="/Report/Details/${item.id}">
                                    <div class="fw-bold text-dark mb-1">
                                        <i class="fa-solid fa-circle text-primary" style="font-size: 8px;"></i>
                                        ${item.title}
                                    </div>
                                    <div class="text-muted text-truncate" style="max-width: 280px;">${item.note}</div>
                                    <div class="text-primary mt-1" style="font-size: 0.7rem;"><i class="fa-regular fa-clock me-1"></i>${item.timeAgo}</div>
                                </a>
                            </li>
                        `).join('');
                    }
                } else {
                    if (badge) badge.style.display = 'none';
                    if (empty) {
                        empty.style.display = 'block';
                        empty.innerHTML = `
                            <i class="fa-regular fa-bell-slash fs-4 mb-2"></i>
                            <div class="small">Không có thông báo mới</div>
                        `;
                    }
                    if (list) list.innerHTML = '';
                }
            } catch (error) {
                console.error('Lỗi tải thông báo:', error);
            }
        }

        $(document).ready(function() {
            if (document.getElementById('handlerNotifBadge')) {
                loadHandlerNotifications();
                setInterval(loadHandlerNotifications, 60000);
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>