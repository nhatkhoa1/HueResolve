<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HueResolve Handler</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --sidebar-width: 260px;
            --header-height: 70px;
            --handler-bg: #f8fafc;
            --handler-indigo: #4f46e5; /* Màu chủ đạo của Handler */
            --handler-indigo-hover: #4338ca;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--handler-bg);
            color: var(--text-main);
            overflow-x: hidden;
        }

        #wrapper { display: flex; }

        /* Content Area */
        #page-content-wrapper {
            width: 100%;
            min-height: 100vh;
            margin-left: var(--sidebar-width);
            transition: all 0.3s;
        }

        .main-content {
            padding: 2rem;
            min-height: calc(100vh - var(--header-height) - 60px);
        }

        /* Responsive */
        @@media (max-width: 992px) {
            #page-content-wrapper { margin-left: 0; }
            #sidebar-wrapper { margin-left: calc(-1 * var(--sidebar-width)); }
            #wrapper.toggled #sidebar-wrapper { margin-left: 0; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="wrapper">
        @await Html.PartialAsync("_Sidebar")

        <div id="page-content-wrapper">
            @await Html.PartialAsync("_Header")

            <main class="main-content">
                @RenderBody()
            </main>

            @await Html.PartialAsync("_Footer")
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $("#menu-toggle").click(function(e) {
            e.preventDefault();
            $("#wrapper").toggleClass("toggled");
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>