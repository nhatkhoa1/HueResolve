@model HueResolve.Models.Model.Department
@{
    ViewData["Title"] = "Xác nhận xóa Đơn vị";
}

<div class="mb-4">
    <a href="@Url.Action("Index")" class="text-decoration-none text-muted fw-medium small">
        <i class="fa-solid fa-arrow-left me-1"></i> Quay lại danh sách
    </a>
    <h4 class="fw-bold mt-2" style="color: var(--text-main);">Xác nhận xóa Đơn vị</h4>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-4 p-xl-5 text-center">
        <div class="mb-4">
            <i class="fa-solid fa-trash-can text-danger" style="font-size: 4rem;"></i>
        </div>
        <h5 class="fw-bold text-dark mb-3">Bạn có chắc chắn muốn xóa vĩnh viễn đơn vị này?</h5>
        <p class="text-muted mb-5">Hành động này sẽ xóa dữ liệu của <b>@Model.Name</b> khỏi hệ thống và không thể hoàn tác.</p>

        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="bg-light rounded-4 p-4 mb-5 text-start">
                    <div class="mb-2 small text-muted text-uppercase fw-bold" style="letter-spacing: 0.5px;">Thông tin đơn vị</div>
                    <div class="fw-bold text-dark fs-5">@Model.Name</div>
                    <div class="text-muted small mb-3">@Model.Type</div>

                    <div class="d-flex gap-4">
                        <div>
                            <div class="small text-muted">Số điện thoại</div>
                            <div class="fw-medium">@Model.PhoneNumber</div>
                        </div>
                        <div>
                            <div class="small text-muted">Email</div>
                            <div class="fw-medium">@Model.Email</div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-3 justify-content-center">
                    <a href="@Url.Action("Index")" class="btn btn-light rounded-3 px-5 py-2 fw-bold shadow-sm border">
                        HỦY BỎ
                    </a>
                    <form action="@Url.Action("Delete")" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger rounded-3 px-5 py-2 fw-bold shadow-sm">
                            XÁC NHẬN XÓA
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>