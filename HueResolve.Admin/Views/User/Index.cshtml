@model IEnumerable<HueResolve.Models.Model.User>
@{
    ViewData["Title"] = "Quản lý Tài khoản";

    int currentPage = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;
    int totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    int totalCount = ViewBag.TotalCount != null ? (int)ViewBag.TotalCount : 0;

    var tabs = new[] {
        new { RoleId = (int?)null, Name = "Tất cả"      },
        new { RoleId = (int?)1,    Name = "Admin"        },
        new { RoleId = (int?)2,    Name = "Cán bộ IOC"   },
        new { RoleId = (int?)4,    Name = "Cán bộ xử lý" },
        new { RoleId = (int?)3,    Name = "Công dân"     }
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0" style="color: var(--text-main);">Quản lý Tài khoản</h4>
    <a href="@Url.Action("Create")" class="btn text-white fw-medium shadow-sm" style="background: var(--accent-success); border-radius: 8px;">
        <i class="fa-solid fa-plus me-2"></i> Thêm Tài khoản
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4 fw-medium">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-4 fw-medium">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["Error"]
    </div>
}

<ul class="nav nav-pills mb-4 gap-2">
    @foreach (var tab in tabs)
    {
        bool isActive = ViewBag.CurrentRoleId == tab.RoleId;
        <li class="nav-item">
            <a class="nav-link rounded-pill px-4 py-2 fw-medium border @(isActive ? "active shadow-sm" : "bg-white text-muted")"
               style="@(isActive ? "background: var(--accent-blue); color: white; border-color: var(--accent-blue);" : "border-color: var(--border-color);")"
               href="@Url.Action("Index", new { roleId = tab.RoleId, search = ViewBag.CurrentSearch })">
                @tab.Name
            </a>
        </li>
    }
</ul>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
        <form method="get" action="@Url.Action("Index")" class="row g-2">
            <input type="hidden" name="roleId" value="@ViewBag.CurrentRoleId" />
            <div class="col-md-10">
                <input type="text" name="search" value="@ViewBag.CurrentSearch" class="form-control form-control-sm rounded-3" placeholder="Tìm theo tên hoặc tài khoản..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-sm w-100 text-white fw-medium shadow-sm" style="background: var(--accent-blue); border-radius: 8px;">
                    <i class="fa-solid fa-magnifying-glass me-1"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead style="background: var(--content-bg); color: var(--text-muted); font-size: 0.85rem;">
                <tr>
                    <th class="py-3 ps-4 border-0">HỌ TÊN / TÀI KHOẢN</th>
                    <th class="py-3 border-0">SỐ ĐIỆN THOẠI</th>
                    <th class="py-3 border-0">VAI TRÒ</th>
                    <th class="py-3 border-0">TRẠNG THÁI</th>
                    <th class="py-3 border-0 text-end pe-4">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">Không tìm thấy tài khoản nào.</td>
                    </tr>
                }
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-dark">@user.FullName</div>
                            <div class="text-muted small">@@@user.Username</div>
                            @if (user.DepartmentId.HasValue && user.RoleId == 4)
                            {
                                <div class="text-muted small">
                                    <i class="fa-solid fa-building me-1" style="font-size: 0.7rem;"></i>
                                    Đơn vị #@user.DepartmentId
                                </div>
                            }
                        </td>
                        <td class="text-muted small">@user.PhoneNumber</td>
                        <td>
                            @switch (user.RoleId)
                            {
                                case 1:
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3">Admin</span>
                                    break;
                                case 2:
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3">Cán bộ IOC</span>
                                    break;
                                case 4:
                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-3">Cán bộ xử lý</span>
                                    break;
                                case 3:
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3">Công dân</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3">Khác</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="text-success small fw-bold"><i class="fa-solid fa-circle me-1" style="font-size: 8px;"></i> Hoạt động</span>
                            }
                            else
                            {
                                <span class="text-danger small fw-bold"><i class="fa-solid fa-circle me-1" style="font-size: 8px;"></i> Đã khóa</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group btn-group-sm" role="group" style="gap: 4px;">
                                <a href="@Url.Action("Details", new { id = user.Id })" 
                                   class="btn btn-outline-primary rounded-3 py-1 px-2 fw-medium" 
                                   title="Xem chi tiết">
                                    <i class="fa-solid fa-eye me-1"></i>Chi tiết
                                </a>
                                <a href="@Url.Action("ChangePassword", new { id = user.Id })" 
                                   class="btn btn-outline-warning rounded-3 py-1 px-2 fw-medium" 
                                   title="Đổi mật khẩu">
                                    <i class="fa-solid fa-key me-1"></i>Mật khẩu
                                </a>
                                @if (user.RoleId != 1)
                                {
                                    <button type="button" 
                                            class="btn btn-outline-danger rounded-3 py-1 px-2 fw-medium"
                                            style="color: @(user.IsActive ? "#ef4444" : "#10b981"); border-color: @(user.IsActive ? "#ef4444" : "#10b981");"
                                            onclick="openToggleModal('@user.Id', '@(user.IsActive ? "false" : "true")', '@user.FullName')"
                                            title="@(user.IsActive ? "Khóa tài khoản" : "Mở khóa tài khoản")">
                                        <i class="fa-solid @(user.IsActive ? "fa-ban" : "fa-lock-open") me-1"></i>@(user.IsActive ? "Khóa" : "Mở")
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small fw-medium"><i class="fa-solid fa-shield-halved me-1"></i>Bảo vệ</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="card-footer bg-white border-top-0 p-3">
            <nav>
                <ul class="pagination pagination-sm justify-content-center m-0">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link border-0 rounded-3 mx-1 @(i == currentPage ? "text-white" : "text-dark fw-bold")"
                               style="@(i == currentPage ? "background: var(--accent-blue);" : "")"
                               href="@Url.Action("Index", new { page = i, roleId = ViewBag.CurrentRoleId, search = ViewBag.CurrentSearch })">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

<div class="modal fade" id="toggleConfirmModal" tabindex="-1" aria-labelledby="toggleConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pt-0 pb-4 px-4">
                <i class="fa-solid fa-circle-exclamation mb-3" id="modalIcon" style="font-size: 3.5rem;"></i>
                <h5 class="fw-bold mb-3" id="toggleConfirmModalLabel">Xác nhận thao tác</h5>
                <p class="text-muted mb-0" id="modalMessage"></p>
            </div>
            <div class="modal-footer border-0 d-flex justify-content-center pt-0 pb-4">
                <button type="button" class="btn btn-light rounded-3 px-4 fw-medium" data-bs-dismiss="modal">Hủy bỏ</button>
                <form id="formToggleStatus" action="@Url.Action("ToggleStatus")" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="hiddenUserId" value="" />
                    <input type="hidden" name="isActive" id="hiddenIsActive" value="" />
                    <button type="submit" class="btn text-white rounded-3 px-4 fw-medium" id="btnConfirmAction">Xác nhận</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function openToggleModal(userId, isActiveStr, fullName) {
        document.getElementById('hiddenUserId').value  = userId;
        document.getElementById('hiddenIsActive').value = isActiveStr;

        const isLocking  = isActiveStr === 'false';
        const actionText = isLocking ? 'khóa' : 'mở khóa';
        const color      = isLocking ? '#ef4444' : '#10b981';

        document.getElementById('modalMessage').innerHTML =
            `Bạn có chắc chắn muốn <b style="color: ${color}">${actionText}</b> tài khoản của <b>${fullName}</b> không?`;

        document.getElementById('modalIcon').style.color       = color;
        document.getElementById('btnConfirmAction').style.backgroundColor = color;
        document.getElementById('btnConfirmAction').innerText  = isLocking ? 'Khóa ngay' : 'Mở khóa ngay';

        new bootstrap.Modal(document.getElementById('toggleConfirmModal')).show();
    }
</script>
