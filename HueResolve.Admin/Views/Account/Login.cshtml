@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Hue Resolve</title>

    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --sidebar-bg: #0f172a;
            --accent-blue: #3b82f6;
            --accent-success: #10b981;
            --content-bg: #f8fafc;
            --border-color: #e2e8f0;
            --text-main: #1e293b;
            --text-muted: #64748b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: var(--content-bg);
            display: flex;
            align-items: stretch;
        }

        /* ── Panel trái: banner thương hiệu ── */
        .login-brand-panel {
            width: 45%;
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem;
            position: relative;
            overflow: hidden;
        }

            .login-brand-panel::before {
                content: '';
                position: absolute;
                width: 500px;
                height: 500px;
                border-radius: 50%;
                background: rgba(59,130,246,0.08);
                top: -100px;
                left: -100px;
            }

            .login-brand-panel::after {
                content: '';
                position: absolute;
                width: 300px;
                height: 300px;
                border-radius: 50%;
                background: rgba(16,185,129,0.06);
                bottom: -60px;
                right: -60px;
            }

        .brand-logo {
            width: 72px;
            height: 72px;
            background: var(--accent-blue);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            position: relative;
            z-index: 1;
            box-shadow: 0 8px 24px rgba(59,130,246,0.35);
        }

        .brand-name {
            font-size: 2rem;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: 1px;
            position: relative;
            z-index: 1;
        }

            .brand-name span {
                color: var(--accent-success);
            }

        .brand-tagline {
            color: #64748b;
            font-size: 0.85rem;
            text-align: center;
            margin-top: 0.5rem;
            position: relative;
            z-index: 1;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
        }

        .brand-stats {
            margin-top: 3rem;
            display: flex;
            gap: 2rem;
            position: relative;
            z-index: 1;
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--accent-success);
        }

        .stat-label {
            font-size: 0.72rem;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ── Panel phải: form đăng nhập ── */
        .login-form-panel {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 2rem;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
        }

            .login-card h2 {
                font-size: 1.6rem;
                font-weight: 700;
                color: var(--text-main);
                margin-bottom: 0.25rem;
            }

            .login-card .subtitle {
                color: var(--text-muted);
                font-size: 0.875rem;
                margin-bottom: 2rem;
            }

        .form-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-main);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.4rem;
            display: block;
        }

        .input-group-icon {
            position: relative;
            margin-bottom: 1rem;
        }

            .input-group-icon i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 0.9rem;
                z-index: 2;
            }

            .input-group-icon input {
                width: 100%;
                height: 48px;
                padding-left: 2.6rem;
                border: 1.5px solid var(--border-color);
                border-radius: 10px;
                font-size: 0.9rem;
                font-family: inherit;
                background: #fff;
                color: var(--text-main);
                transition: border-color 0.2s, box-shadow 0.2s;
                outline: none;
            }

                .input-group-icon input:focus {
                    border-color: var(--accent-blue);
                    box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
                }

        .alert-login-error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            color: #dc2626;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.25rem;
        }

        .btn-login {
            width: 100%;
            height: 48px;
            background: var(--accent-blue);
            color: #ffffff;
            border: none;
            border-radius: 10px;
            font-size: 0.95rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: background 0.2s, transform 0.1s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

            .btn-login:hover {
                background: #2563eb;
            }

            .btn-login:active {
                transform: scale(0.98);
            }

        .login-footer {
            text-align: center;
            margin-top: 2rem;
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        @@media (max-width: 768px) {
            .login-brand-panel {
                display: none;
            }

            .login-form-panel {
                padding: 2rem 1.5rem;
            }
        }
    </style>
</head>
<body>

    <!-- Panel trái: thương hiệu -->
    <div class="login-brand-panel">
        <div class="brand-logo">
            <i class="fa-solid fa-shield-halved text-white" style="font-size: 2rem;"></i>
        </div>
        <div class="brand-name">HUE <span>RESOLVE</span></div>
        <div class="brand-tagline">Vì một cố đô Xanh – Sạch – Sáng</div>

        <div class="brand-stats">
            <div class="stat-item">
                <div class="stat-number">183K+</div>
                <div class="stat-label">Phản ánh xử lý</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">98%</div>
                <div class="stat-label">Tỉ lệ hài lòng</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">900K+</div>
                <div class="stat-label">Lượt tải Hue-S</div>
            </div>
        </div>
    </div>

    <!-- Panel phải: form -->
    <div class="login-form-panel">
        <div class="login-card">
            <h2>Chào mừng trở lại</h2>
            <p class="subtitle">Đăng nhập vào hệ thống quản trị <strong>Hue Resolve IOC</strong></p>

            <!-- Thông báo lỗi từ Controller (nếu có) -->
            @if (ViewBag.Error != null)
            {
                <div class="alert-login-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    @ViewBag.Error
                </div>
            }

            <form action="/Account/Login" method="post">
                @Html.AntiForgeryToken()

                <!-- Tên đăng nhập -->
                <div class="mb-3">
                    <label class="form-label" for="username">Tên đăng nhập</label>
                    <div class="input-group-icon">
                        <i class="fa-regular fa-user"></i>
                        <input type="text"
                               id="username"
                               name="username"
                               placeholder="Nhập tên đăng nhập..."
                               value="@(ViewBag.Username ?? string.Empty)"
                               autocomplete="username"
                               autofocus
                               required />
                    </div>
                </div>

                <!-- Mật khẩu -->
                <div class="mb-3">
                    <label class="form-label" for="password">Mật khẩu</label>
                    <div class="input-group-icon">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password"
                               id="password"
                               name="password"
                               placeholder="Nhập mật khẩu..."
                               autocomplete="current-password"
                               required />
                    </div>
                </div>

                <button type="submit" class="btn-login">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    Đăng nhập
                </button>
            </form>

            <div class="login-footer">
                © 2026 <strong>Hue Resolve</strong> · Hệ thống Phản ánh Hiện trường Thông minh
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
