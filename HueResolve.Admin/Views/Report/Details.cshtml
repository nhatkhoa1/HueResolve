@model HueResolve.Models.Model.Report
@{
    ViewData["Title"] = "Chi tiết Phản ánh";
    var timeline = ViewBag.Timeline as IEnumerable<HueResolve.Models.Model.ReportStatusHistory> ?? Enumerable.Empty<HueResolve.Models.Model.ReportStatusHistory>();
    var attachments = ViewBag.Attachments as IEnumerable<HueResolve.Models.Model.ReportAttachment> ?? Enumerable.Empty<HueResolve.Models.Model.ReportAttachment>();
    var citizenAttachments = attachments.Where(a => a.AttachmentType == "Citizen").ToList();
    var resultAttachments = attachments.Where(a => a.AttachmentType == "Result").ToList();
    var departments = ViewBag.Departments as IEnumerable<HueResolve.Models.Model.Department> ?? Enumerable.Empty<HueResolve.Models.Model.Department>();
    var categories = ViewBag.Categories as IEnumerable<HueResolve.Models.Model.Category> ?? Enumerable.Empty<HueResolve.Models.Model.Category>();
    var assignment = ViewBag.LatestAssignment as HueResolve.Models.Model.Assignment;

    var categoryName = categories.FirstOrDefault(c => c.Id == Model.CategoryId)?.Name ?? "Chưa phân loại";

    var (statusBadgeClass, statusText) = Model.Status switch
    {
        "TiepNhan" => ("bg-primary bg-opacity-10 text-primary", "Tiếp nhận"),
        "DangXuLy" => ("bg-warning bg-opacity-10 text-warning", "Đang xử lý"),
        "ChoDuyetKq" => ("bg-info bg-opacity-10 text-info", "Chờ kết quả duyệt"),
        "HoanThanh" => ("bg-success bg-opacity-10 text-success", "Hoàn thành"),
        "TuChoi" => ("bg-danger  bg-opacity-10 text-danger", "Từ chối"),
        _ => ("bg-secondary bg-opacity-10 text-secondary", Model.Status)
    };
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center gap-3">
            <a href="@Url.Action("Index")" class="btn btn-sm d-flex align-items-center gap-2"
               style="background:#f1f5f9;color:var(--text-main);border:1px solid var(--border-color);border-radius:8px;font-size:0.82rem;font-weight:600;padding:6px 14px;text-decoration:none;">
                <i class="fa-solid fa-arrow-left" style="font-size:0.75rem;"></i>
                Quay lại
            </a>
            <div>
                <div class="text-muted" style="font-size:0.75rem;">Mã phản ánh</div>
                <h5 class="fw-bold mb-0" style="color:var(--text-main);font-size:1rem;">@Model.TrackingCode</h5>
            </div>
        </div>
        <span class="badge rounded-pill px-3 py-2 @statusBadgeClass" style="font-size:0.8rem;">@statusText</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 mb-3 fw-bold small">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-3 fw-bold small">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["Error"]
        </div>
    }

    <div class="row g-3">
        <div class="col-12 col-xl-8">

            <div class="card-stat mb-3 border-0 shadow-sm rounded-4 p-4 bg-white">
                <div class="fw-bold mb-3" style="font-size:0.9rem;color:var(--text-main);">
                    <i class="fa-solid fa-file-lines me-2" style="color:var(--accent-blue);"></i>
                    Thông tin phản ánh
                </div>
                <h6 class="fw-bold mb-1" style="color:var(--text-main);font-size:1rem;">@Model.Title</h6>
                <p class="text-muted mb-3" style="font-size:0.875rem;line-height:1.7;">@Model.Description</p>

                <div class="row g-3 p-3 rounded-3" style="font-size:0.82rem; background:#f8fafc; border:1px solid var(--border-color);">
                    <div class="col-sm-6">
                        <div class="text-muted mb-1" style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">Người gửi</div>
                        <div class="fw-bold text-dark">@(string.IsNullOrEmpty(Model.ReporterName) ? "Nặc danh" : Model.ReporterName)</div>
                        <div class="text-muted">@(string.IsNullOrEmpty(Model.ReporterPhone) ? "Không có" : Model.ReporterPhone)</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted mb-1" style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">Địa điểm</div>
                        <div class="fw-bold text-dark">@Model.AddressText</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted mb-1" style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">Danh mục</div>
                        <div class="fw-bold text-dark">@categoryName</div>
                        @if (Model.AiConfidence.HasValue)
                        {
                            <div class="text-success fw-bold">AI phân loại: @Model.AiConfidence.Value.ToString("P0")</div>
                        }
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted mb-1" style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">Thời gian gửi</div>
                        <div class="fw-bold text-dark">@Model.CreatedAtUtc.AddHours(7).ToString("HH:mm - dd/MM/yyyy")</div>
                    </div>
                </div>
            </div>

            @if (Model.NeedsReview)
            {
                <div class="mb-3 d-flex align-items-start gap-3 p-3 shadow-sm" style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;font-size:0.85rem;">
                    <i class="fa-solid fa-triangle-exclamation mt-1" style="color:#d97706;"></i>
                    <div>
                        <div class="fw-bold" style="color:#92400e;">AI phân loại không chắc chắn</div>
                        <div style="color:#b45309;">Độ tin cậy @(Model.AiConfidence.HasValue? Model.AiConfidence.Value.ToString("P0") : "N/A") — Ban điều hành cần kiểm tra lại danh mục trước khi phân công.</div>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.ResolutionNote))
            {
                <div class="card-stat mb-3 border-0 shadow-sm rounded-4 p-4 bg-white">
                    <div class="fw-bold mb-2" style="font-size:0.9rem;color:var(--text-main);">
                        <i class="fa-solid fa-clipboard-check me-2" style="color:var(--accent-success);"></i> Kết quả xử lý từ Đơn vị
                    </div>
                    <p class="mb-0 p-3 rounded-3" style="font-size:0.875rem;color:var(--text-main);line-height:1.7; background:#f0fdf4; border:1px solid #bbf7d0;">
                        @Model.ResolutionNote
                    </p>
                </div>
            }

            <div class="card-stat mb-3 border-0 shadow-sm rounded-4 p-4 bg-white">
                <div class="fw-bold mb-3" style="font-size:0.9rem;color:var(--text-main);">
                    <i class="fa-solid fa-images me-2" style="color:var(--accent-blue);"></i>
                    Ảnh minh chứng từ người dân <span class="ms-1 text-muted fw-normal" style="font-size:0.8rem;">(@citizenAttachments.Count file)</span>
                </div>

                @{ int attIdx = 0; }
                @if (citizenAttachments.Any())
                {
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        @foreach (var att in citizenAttachments)
                        {
                            string base64Data = att.FileData != null ? $"data:{att.ContentType};base64,{Convert.ToBase64String(att.FileData)}" : "/img/no-image.png";

                            <div class="gallery-thumb shadow-sm" onclick="openLightbox(@attIdx)"
                                 style="width:110px;height:110px;border-radius:10px;border:1px solid var(--border-color); overflow:hidden;cursor:pointer;position:relative;background:#f1f5f9;flex-shrink:0;">
                                <img src="@base64Data" alt="@att.OriginalFileName" style="width:100%;height:100%;object-fit:cover;" />
                                <div class="thumb-overlay">
                                    <i class="fa-solid fa-magnifying-glass-plus" style="color:#fff;font-size:1.2rem;"></i>
                                </div>
                            </div>
                            attIdx++;
                        }
                    </div>
                }
                else
                {
                    <div class="p-3 text-center bg-light rounded-3 text-muted mb-4" style="font-size: 0.85rem;">
                        <i>Không có ảnh minh chứng từ người dân</i>
                    </div>
                }

                <div class="fw-bold mb-3" style="font-size:0.9rem;color:var(--text-main);">
                    <i class="fa-solid fa-camera-retro me-2" style="color:var(--accent-success);"></i>
                    Ảnh kết quả xử lý <span class="ms-1 text-muted fw-normal" style="font-size:0.8rem;">(@resultAttachments.Count file)</span>
                </div>

                @if (resultAttachments.Any())
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var att in resultAttachments)
                        {
                            string base64Data = att.FileData != null ? $"data:{att.ContentType};base64,{Convert.ToBase64String(att.FileData)}" : "/img/no-image.png";

                            <div class="gallery-thumb shadow-sm" onclick="openLightbox(@attIdx)"
                                 style="width:110px;height:110px;border-radius:10px;border:1px solid var(--border-color); overflow:hidden;cursor:pointer;position:relative;background:#f1f5f9;flex-shrink:0;">
                                <img src="@base64Data" alt="@att.OriginalFileName" style="width:100%;height:100%;object-fit:cover;" />
                                <div class="thumb-overlay">
                                    <i class="fa-solid fa-magnifying-glass-plus" style="color:#fff;font-size:1.2rem;"></i>
                                </div>
                            </div>
                            attIdx++;
                        }
                    </div>
                }
                else
                {
                    <div class="p-3 text-center bg-light rounded-3 text-muted" style="font-size: 0.85rem;">
                        <i>Chưa có ảnh kết quả xử lý</i>
                    </div>
                }
            </div>

            <div class="card-stat border-0 shadow-sm rounded-4 p-4 bg-white">
                <div class="fw-bold mb-4 border-bottom pb-2" style="font-size:0.9rem;color:var(--text-main);">
                    <i class="fa-solid fa-timeline me-2" style="color:var(--accent-blue);"></i> Lịch sử xử lý
                </div>
                @if (timeline.Any())
                {
                    <div style="position:relative; margin-left: 10px; border-left: 2px solid #e2e8f0; padding-left: 20px;">
                        @foreach (var step in timeline)
                        {
                            var (dotColor, stepLabel) = step.Status switch
                            {
                                "TiepNhan" => ("#3b82f6", "Tiếp nhận"),
                                "DangXuLy" => ("#eab308", "Đang xử lý"),
                                "HoanThanh" => ("#10b981", "Hoàn thành"),
                                "TuChoi" => ("#ef4444", "Từ chối"),
                                _ => ("#94a3b8", step.Status)
                            };
                            <div class="mb-4 position-relative">
                                <span class="position-absolute rounded-circle shadow-sm" style="width:14px;height:14px;background:@dotColor;left:-28px;top:4px; border: 2px solid #fff;"></span>
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="fw-bold" style="font-size:0.9rem;color:var(--text-main);">@stepLabel</span>
                                    <span class="text-muted" style="font-size:0.75rem;">
                                        <i class="fa-regular fa-clock me-1"></i> @step.CreatedAtUtc.AddHours(7).ToString("HH:mm - dd/MM/yyyy")
                                    </span>
                                </div>
                                @if (!string.IsNullOrEmpty(step.UpdatedByName))
                                {
                                    <div class="text-muted mb-2" style="font-size:0.78rem;">
                                        <i class="fa-regular fa-user me-1"></i> Bởi: <b>@step.UpdatedByName</b>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(step.Note))
                                {
                                    <div class="p-2 bg-light rounded-3 mt-1" style="font-size:0.85rem;color:var(--text-main); border: 1px solid var(--border-color);">
                                        @step.Note
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-12 col-xl-4">

            <div class="card-stat mb-3 border-0 shadow-sm rounded-4 p-4 bg-white">
                <div class="fw-bold mb-3 border-bottom pb-2" style="font-size:0.9rem;color:var(--text-main);">
                    <i class="fa-solid fa-building-shield me-2" style="color:var(--accent-blue);"></i> Phân công đơn vị
                </div>

                @if (assignment != null)
                {
                    <div class="mb-3 p-3 shadow-sm" style="background:#f0fdf4;border-radius:8px;border:1px solid #bbf7d0;font-size:0.82rem;">
                        <div class="fw-bold" style="color:#065f46;"><i class="fa-solid fa-check-circle me-1"></i> Đã phân công lúc:</div>
                        <div class="text-muted mb-2">@assignment.AssignedAtUtc.AddHours(7).ToString("dd/MM/yyyy HH:mm")</div>
                        <div class="fw-bold" style="color:#065f46;">Đơn vị đảm nhận:</div>
                        <div class="text-dark">@(departments.FirstOrDefault(d => d.Id == assignment.DepartmentId)?.Name ?? "Không rõ")</div>
                        @if (!string.IsNullOrEmpty(assignment.Note))
                        {
                            <hr style="border-color: #bbf7d0;">
                            <div class="mt-1" style="color:#065f46;"><b>Chỉ đạo:</b> @assignment.Note</div>
                        }
                    </div>
                }

                @if (Model.Status == "TiepNhan")
                {
                    <form action="@Url.Action("AssignDepartment", "Report")" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="mb-3">
                            <label class="form-label" style="font-size:0.78rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;">Đơn vị tiếp nhận <span class="text-danger">*</span></label>
                            <select name="departmentId" class="form-select shadow-sm" style="font-size:0.85rem;border-radius:8px;" required>
                                <option value="">-- Chọn đơn vị --</option>
                                @foreach (var dept in departments)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="font-size:0.78rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;">Ghi chú chỉ đạo</label>
                            <input type="text" name="note" class="form-control shadow-sm" style="font-size:0.85rem;border-radius:8px;" placeholder="Nhập yêu cầu đặc biệt..." />
                        </div>

                        <button type="submit" class="btn w-100 shadow-sm" style="background:#0f172a;color:#fff;border:none;border-radius:8px;font-size:0.85rem;font-weight:600;padding:.6rem;">
                            <i class="fa-solid fa-paper-plane me-1"></i> Điều phối ngay
                        </button>
                    </form>
                }
            </div>

            @if (Model.Status == "ChoDuyetKq")
            {
                <div class="card-stat mb-3 border-0 shadow-sm rounded-4 p-4 bg-white border border-info border-2">
                    <div class="fw-bold mb-3 border-bottom pb-2 text-info" style="font-size:0.9rem;">
                        <i class="fa-solid fa-clipboard-user me-2"></i> Duyệt kết quả xử lý
                    </div>
                    <form action="@Url.Action("ApproveResult", "Report")" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label" style="font-size:0.78rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;">Ghi chú duyệt/trả về <span class="text-danger">*</span></label>
                            <textarea name="adminNote" rows="2" class="form-control shadow-sm" style="font-size:0.85rem;border-radius:8px;resize:none;" placeholder="Ghi nhận hoàn thành hoặc nêu rõ lý do yêu cầu làm lại..." required></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-success flex-fill shadow-sm" style="border-radius:8px;font-size:0.85rem;font-weight:600;padding:.6rem;" onclick="showApproveConfirm(true)">
                                <i class="fa-solid fa-check me-1"></i> Duyệt (Gửi kết quả cho công dân)
                            </button>
                            <button type="button" class="btn btn-warning flex-fill shadow-sm text-dark" style="border-radius:8px;font-size:0.85rem;font-weight:600;padding:.6rem;" onclick="showApproveConfirm(false)">
                                <i class="fa-solid fa-rotate-left me-1"></i> Gửi lại cho đơn vị xử lý
                            </button>
                        </div>
                        
                        <!-- Hidden inputs to store the decision for the form -->
                        <input type="hidden" name="isApproved" id="hiddenIsApproved" value="true" />
                    </form>
                </div>
            }

            <div class="card-stat mb-3 border-0 shadow-sm rounded-4 p-4 bg-white">
                <div class="fw-bold mb-3 border-bottom pb-2" style="font-size:0.9rem;color:var(--text-main);">
                    <i class="fa-solid fa-comment-dots me-2" style="color:var(--accent-blue);"></i> Phản hồi cho người dân
                </div>
                @if (!string.IsNullOrEmpty(Model.AdminFeedback))
                {
                    <div class="mb-3 p-3 shadow-sm" style="background:#f8fafc;border-radius:8px;border:1px solid var(--border-color);font-size:0.85rem;color:var(--text-main);">
                        <span class="badge bg-primary bg-opacity-10 text-primary mb-2">Đã phản hồi</span><br />
                        @Model.AdminFeedback
                    </div>
                }
                <form action="@Url.Action("SaveFeedback", "Report")" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="reportId" value="@Model.Id" />
                    <div class="mb-3">
                        <textarea name="adminFeedback" rows="3" class="form-control shadow-sm" style="font-size:0.85rem;border-radius:8px;resize:none;" placeholder="Nhập phản hồi công khai..."></textarea>
                    </div>
                    <button type="submit" class="btn w-100 shadow-sm" style="background:#eff6ff;color:var(--accent-blue);border:1px solid #bfdbfe;border-radius:8px;font-size:0.85rem;font-weight:600;padding:.6rem;">
                        <i class="fa-solid fa-floppy-disk me-1"></i> Lưu phản hồi
                    </button>
                </form>
            </div>

            @if (Model.Status == "TiepNhan")
            {
                <div class="card-stat border-0 shadow-sm rounded-4 p-4 bg-white">
                    <div class="fw-bold mb-3 border-bottom pb-2 text-danger" style="font-size:0.9rem;">
                        <i class="fa-solid fa-ban me-2"></i> Từ chối phản ánh
                    </div>
                    <form action="@Url.Action("Reject", "Report")" method="post" id="rejectForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-3">
                            <select name="reason" id="rejectReason" class="form-select shadow-sm" required style="font-size:0.85rem;border-radius:8px;">
                                <option value="">-- Chọn lý do --</option>
                                <option value="Thông tin không chính xác">Thông tin không chính xác</option>
                                <option value="Nội dung spam/phá hoại">Nội dung spam/phá hoại</option>
                                <option value="Đã được xử lý trước đó">Đã được xử lý trước đó</option>
                                <option value="Khác">Lý do khác...</option>
                            </select>
                        </div>
                        <button type="button" class="btn btn-danger w-100 shadow-sm" style="border-radius:8px;font-size:0.85rem;font-weight:600;padding:.6rem;" onclick="showRejectConfirm()">
                            <i class="fa-solid fa-xmark me-1"></i> Xác nhận từ chối
                        </button>
                    </form>
                </div>
            }

        </div>
    </div>
</div>

<div id="lightbox" onclick="closeLightbox()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:9999;align-items:center;justify-content:center;flex-direction:column;">
    <button onclick="closeLightbox()" class="border-0" style="position:absolute;top:20px;right:24px;background:rgba(255,255,255,0.12);color:#fff;border-radius:50%;width:40px;height:40px;font-size:1rem;cursor:pointer;z-index:10000;">
        <i class="fa-solid fa-xmark"></i>
    </button>
    <button id="lb-prev" onclick="event.stopPropagation();shiftLightbox(-1)" class="border-0" style="position:absolute;left:20px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.12);color:#fff;border-radius:50%;width:44px;height:44px;font-size:1rem;cursor:pointer;">
        <i class="fa-solid fa-chevron-left"></i>
    </button>
    <button id="lb-next" onclick="event.stopPropagation();shiftLightbox(1)" class="border-0" style="position:absolute;right:20px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.12);color:#fff;border-radius:50%;width:44px;height:44px;font-size:1rem;cursor:pointer;">
        <i class="fa-solid fa-chevron-right"></i>
    </button>
    <div id="lb-content" onclick="event.stopPropagation()" style="max-width:90vw;max-height:82vh;display:flex;align-items:center;justify-content:center;"></div>
    <div id="lb-caption" style="color:rgba(255,255,255,0.6);font-size:0.8rem;margin-top:12px;text-align:center;"></div>
    <div id="lb-counter" style="color:rgba(255,255,255,0.4);font-size:0.75rem;margin-top:4px;"></div>
</div>

@section Scripts {
    <style>
        .thumb-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity .2s;
        }

        .gallery-thumb:hover .thumb-overlay {
            opacity: 1;
        }

        .gallery-thumb:hover {
            border-color: #93c5fd !important;
        }
    </style>
    <script>
        /// <summary>Tạo mảng JSON chứa dữ liệu ảnh Base64 cho Lightbox</summary>
        const _attachments = [
            @foreach (var att in attachments)
            {
                    /// Chuyển đổi mảng byte sang chuỗi Base64
                    string jsBase64 = att.FileData != null ? $"data:{att.ContentType};base64,{Convert.ToBase64String(att.FileData)}" : "/img/no-image.png";
                    <text>
                    {
                        /// Sử dụng Html.Raw để trình duyệt không encode chuỗi Base64
                        src: "@Html.Raw(jsBase64)",
                        name: "@Html.Raw(att.OriginalFileName)"
                    },
                    </text>
            }
        ];

        let _lbIdx = 0;

        function openLightbox(idx) {
            _lbIdx = idx;
            renderLightbox();
            document.getElementById('lightbox').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            document.getElementById('lightbox').style.display = 'none';
            document.body.style.overflow = '';
            document.getElementById('lb-content').innerHTML = '';
        }

        function shiftLightbox(dir) {
            _lbIdx = (_lbIdx + dir + _attachments.length) % _attachments.length;
            renderLightbox();
        }

        function renderLightbox() {
            if (_attachments.length === 0) return;
            const att = _attachments[_lbIdx];
            const c = document.getElementById('lb-content');
            c.innerHTML = '';

            const img = document.createElement('img');
            img.src = att.src;
            img.style.cssText = 'max-width:90vw;max-height:80vh;object-fit:contain;border-radius:8px;box-shadow: 0 10px 25px rgba(0,0,0,0.5);';
            c.appendChild(img);

            document.getElementById('lb-caption').textContent = att.name;
            document.getElementById('lb-counter').textContent = (_lbIdx + 1) + ' / ' + _attachments.length;

            /// Ẩn hiện nút điều hướng nếu chỉ có 1 ảnh
            document.getElementById('lb-prev').style.display = _attachments.length > 1 ? '' : 'none';
            document.getElementById('lb-next').style.display = _attachments.length > 1 ? '' : 'none';
        }

        document.addEventListener('keydown', function(e) {
            if (document.getElementById('lightbox').style.display === 'none') return;
            if (e.key === 'ArrowLeft')  shiftLightbox(-1);
            if (e.key === 'ArrowRight') shiftLightbox(1);
            if (e.key === 'Escape')     closeLightbox();
        });
    </script>
    
    <!-- Modal Thông báo Thành công -->
    <div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-body text-center p-5">
                    <div class="mb-4">
                        <i class="fa-solid fa-circle-check text-success" style="font-size: 4rem;"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Thành công!</h5>
                    <p class="text-muted mb-4">@TempData["Success"]</p>
                    <button type="button" class="btn btn-success w-100 rounded-3 fw-bold py-2" data-bs-dismiss="modal">ĐÓNG</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Xác nhận Duyệt/Trả về -->
    <div class="modal fade" id="approveConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="fw-bold m-0">Xác nhận thao tác</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4">
                    <p id="approveConfirmMessage" class="mb-0 text-muted"></p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-3 px-4 fw-bold" data-bs-dismiss="modal">HỦY</button>
                    <button type="button" id="btnConfirmApprove" class="btn rounded-3 px-4 fw-bold text-white">XÁC NHẬN</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function showApproveConfirm(isApproved) {
            const modal = new bootstrap.Modal(document.getElementById('approveConfirmModal'));
            const msg = isApproved ? "Bạn xác nhận kết quả đã <b>ĐẠT YÊU CẦU</b> và muốn đóng phản ánh này để gửi kết quả cho công dân?" : "Bạn muốn <b>TRẢ LẠI</b> phản ánh này cho đơn vị để yêu cầu xử lý lại?";
            const btn = document.getElementById('btnConfirmApprove');
            
            document.getElementById('approveConfirmMessage').innerHTML = msg;
            document.getElementById('hiddenIsApproved').value = isApproved;
            
            btn.className = isApproved ? "btn btn-success rounded-3 px-4 fw-bold text-white" : "btn btn-warning rounded-3 px-4 fw-bold text-dark";
            
            btn.onclick = function() {
                document.querySelector('form[action*="ApproveResult"]').submit();
            };
            
            modal.show();
        }

        function showRejectConfirm() {
            const reason = document.getElementById('rejectReason').value;
            if (!reason) {
                alert("Vui lòng chọn lý do từ chối trước.");
                return;
            }

            const modal = new bootstrap.Modal(document.getElementById('approveConfirmModal'));
            document.getElementById('approveConfirmMessage').innerHTML = `Bạn có chắc chắn muốn <b>TỪ CHỐI</b> phản ánh này với lý do: <i>${reason}</i>?`;
            
            const btn = document.getElementById('btnConfirmApprove');
            btn.className = "btn btn-danger rounded-3 px-4 fw-bold text-white";
            btn.innerText = "XÁC NHẬN TỪ CHỐI";
            
            btn.onclick = function() {
                document.getElementById('rejectForm').submit();
            };
            
            modal.show();
        }
    </script>
}