@model HueResolve.Models.Model.Report
@{
    ViewData["Title"] = "Điều phối xử lý";
    var departments = ViewBag.Departments as IEnumerable<HueResolve.Models.Model.Department>
                      ?? Enumerable.Empty<HueResolve.Models.Model.Department>();
}

<div class="container-fluid px-4 py-4">
    <div class="mb-4">
        <a href="@Url.Action("Index")" class="text-decoration-none text-muted small fw-medium">
            <i class="fa-solid fa-arrow-left me-1"></i> Trở lại danh sách
        </a>
        <h4 class="fw-bold text-dark mt-2">Phân công đơn vị chịu trách nhiệm</h4>
    </div>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <div class="badge bg-primary bg-opacity-10 text-primary mb-3">#@Model.TrackingCode</div>
                    <h5 class="fw-bold text-dark mb-3">@Model.Title</h5>
                    <p class="text-muted small">@Model.Description</p>
                    <div class="p-3 bg-light rounded-3 text-start">
                        <i class="fa-solid fa-location-dot text-danger me-2"></i>
                        <span class="small fw-medium">@Model.AddressText</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <form action="@Url.Action("AssignDepartment", "Report", new { id = Model.Id })" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark small d-flex justify-content-between align-items-center">
                                <span>ĐƠN VỊ XỬ LÝ <span class="text-danger">*</span></span>
                                <button type="button" class="btn btn-sm btn-outline-info rounded-pill fw-bold" id="btnAiSuggest">
                                    <i class="fa-solid fa-wand-magic-sparkles"></i> Gợi ý tự động (AI)
                                </button>
                            </label>
                            <select name="departmentId" id="departmentId" class="form-select rounded-3 py-2 shadow-sm" required>
                                <option value="">-- Chọn đơn vị trong danh sách --</option>
                                @foreach (var d in departments)
                                {
                                    <option value="@d.Id">@d.Name (@d.Type)</option>
                                }
                            </select>
                            <small id="aiMessage" class="text-success d-none mt-1 fw-bold"><i class="fa-solid fa-check"></i> AI đã gợi ý đơn vị phù hợp.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark small">GHI CHÚ CHỈ ĐẠO</label>
                            <textarea name="note" class="form-control rounded-3 shadow-sm" rows="5" placeholder="Nhập yêu cầu cụ thể..."></textarea>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a href="@Url.Action("Index")" class="btn btn-light rounded-3 px-4 fw-bold">HỦY</a>
                            <button type="submit" class="btn btn-primary px-5 fw-bold rounded-3 shadow-sm">
                                XÁC NHẬN PHÂN CÔNG
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnAiSuggest').addEventListener('click', function() {
            var btn = this;
            var originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang phân tích...';
            btn.disabled = true;
            document.getElementById('aiMessage').classList.add('d-none');

            fetch('@Url.Action("SuggestDepartmentAi", "Report", new { id = Model.Id })')
                .then(response => response.json())
                .then(data => {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    
                    if (data.success) {
                        var select = document.getElementById('departmentId');
                        select.value = data.departmentId;
                        
                        var aiMsg = document.getElementById('aiMessage');
                        aiMsg.innerHTML = '<i class="fa-solid fa-check"></i> AI đã tự động phân loại: ' + data.departmentName;
                        aiMsg.classList.remove('d-none');
                        
                        // Highlight dropdown
                        select.classList.add('border-success');
                        setTimeout(() => select.classList.remove('border-success'), 2000);
                    } else {
                        alert(data.message);
                    }
                })
                .catch(err => {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    alert('Lỗi kết nối khi gọi AI.');
                });
        });
    </script>
}