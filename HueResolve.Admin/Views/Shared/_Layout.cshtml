<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HueResolve Quản Trị</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Intro Animation (Premium WOW Admin version, matches Login page branding) */
        .site-intro {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(-45deg, #090d16, #0f172a, #1e293b, #0f172a);
            background-size: 400% 400%;
            animation: gradientBG 4s ease infinite;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.8s cubic-bezier(0.86, 0, 0.07, 1), opacity 0.8s ease;
        }

        .site-intro.fade-out {
            transform: translateY(-100%);
            opacity: 0;
        }

        .intro-glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 28px;
            padding: 50px 70px;
            text-align: center;
            color: white;
            box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.6);
            animation: card-reveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
            transform: scale(0.9);
            opacity: 0;
            min-width: 340px;
        }

        .intro-icon-wrapper {
            position: relative;
            width: 100px;
            height: 100px;
            margin: 0 auto 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            perspective: 1000px;
        }

        .intro-logo {
            font-size: 4.2rem;
            color: #3b82f6; /* Vibrant Blue matching --accent-blue */
            z-index: 2;
            animation: icon-flip 1.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
            filter: drop-shadow(0 0 20px rgba(59, 130, 246, 0.6));
        }

        .intro-rings {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: 2px solid rgba(59, 130, 246, 0.3);
            border-radius: 50%;
            animation: ring-pulse 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
        }

        .intro-rings.ring-2 {
            animation-delay: 0.5s;
            border-color: rgba(16, 185, 129, 0.15); /* Accent success green ring */
        }

        .intro-title {
            font-weight: 800;
            font-size: 3rem;
            letter-spacing: -1px;
            margin-bottom: 0.6rem;
            opacity: 0;
            animation: text-reveal 1s ease-out 0.5s forwards;
            color: #ffffff;
        }

        .text-gradient {
            background: linear-gradient(to right, #10b981, #34d399); /* Emerald Green gradient matches Login RESOLVE */
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .intro-subtitle {
            font-size: 1.15rem;
            color: #94a3b8;
            opacity: 0;
            animation: text-reveal 1s ease-out 0.7s forwards;
            margin-bottom: 35px;
            letter-spacing: 1px;
        }

        .intro-loader-wrapper {
            width: 100%;
            height: 4px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }

        .intro-loader-bar {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #3b82f6, #10b981); /* Blue to Green gradient matches brand theme */
            border-radius: 4px;
            box-shadow: 0 0 12px rgba(59, 130, 246, 0.5);
            animation: load-progress 2.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }

        body.intro-active {
            overflow: hidden;
            max-height: 100vh;
        }

        @@keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        @@keyframes card-reveal {
            to { transform: scale(1); opacity: 1; }
        }

        @@keyframes icon-flip {
            0% { transform: rotateY(180deg) scale(0.5); opacity: 0; }
            50% { transform: rotateY(0deg) scale(1.2); opacity: 1; }
            100% { transform: rotateY(0deg) scale(1); opacity: 1; }
        }

        @@keyframes ring-pulse {
            0% { transform: scale(0.8); opacity: 1; }
            100% { transform: scale(1.5); opacity: 0; }
        }

        @@keyframes text-reveal {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        @@keyframes load-progress {
            0% { width: 0%; }
            45% { width: 45%; }
            75% { width: 80%; }
            100% { width: 100%; }
        }

        .intro-glow-circle {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.08;
            z-index: 1;
            pointer-events: none;
        }

        .circle-1 {
            width: 300px;
            height: 300px;
            background: #3b82f6;
            top: 20%;
            left: 15%;
            animation: float-1 12s ease-in-out infinite;
        }

        .circle-2 {
            width: 350px;
            height: 350px;
            background: #10b981;
            bottom: 20%;
            right: 15%;
            animation: float-2 15s ease-in-out infinite;
        }

        @@keyframes float-1 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(40px, 30px) scale(1.1); }
        }

        @@keyframes float-2 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(-40px, -30px) scale(0.9); }
        }
    </style>
</head>
<body class="d-flex">
    <!-- ═══ INTRO SCREEN ═══ -->
    <div id="site-intro" class="site-intro">
        <!-- Floating ambient glowing circles -->
        <div class="intro-glow-circle circle-1"></div>
        <div class="intro-glow-circle circle-2"></div>

        <div class="intro-glass-card" style="transform-style: preserve-3d; transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 1s ease;">
            <div class="intro-icon-wrapper" style="transform: translateZ(30px);">
                <i class="fa-solid fa-shield-halved intro-logo"></i> <!-- Shield icon to match Admin login page -->
                <div class="intro-rings"></div>
                <div class="intro-rings ring-2"></div>
            </div>
            <h1 class="intro-title" style="transform: translateZ(20px);">
                HUE <span class="text-gradient">RESOLVE</span>
            </h1>
            <p class="intro-subtitle" style="transform: translateZ(15px); transition: opacity 0.3s ease;">Đang bảo mật quyền kiểm soát hệ thống...</p>
            
            <div class="intro-loader-wrapper">
                <div class="intro-loader-bar"></div>
            </div>
        </div>
    </div>
    <script>
        if (sessionStorage.getItem('adminIntroShown')) {
            document.getElementById('site-intro').style.display = 'none';
        } else {
            document.body.classList.add('intro-active');
        }
    </script>
    <!-- ═══ END INTRO ═══ -->
    <partial name="_Sidebar" />

    <div class="w-100">
        <partial name="_Header" />

        <main class="main-content">
            <div class="container-fluid px-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mt-3" role="alert">
                        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 mt-3" role="alert">
                        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            </div>

            @RenderBody()
        </main>

        <footer class="py-3 text-center border-top" style="font-size: 0.8rem; background: #fff; color: #94a3b8;">
            © 2026 <b>Hue Resolve</b>. Một phần của Đô thị Thông minh Huế (<b>Hue-S</b>).
        </footer>
    </div>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        // Tự động đóng các thông báo (Alert) sau 5 giây
        document.addEventListener("DOMContentLoaded", function() {
            setTimeout(function() {
                const alerts = document.querySelectorAll('.alert-dismissible');
                alerts.forEach(function(alert) {
                    const bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
                    if (bsAlert) bsAlert.close();
                });
            }, 5000);

            // Intro screen close and dynamic status trigger
            const intro = document.getElementById('site-intro');
            if (intro && !sessionStorage.getItem('adminIntroShown')) {
                // Dynamic text updates matching loading bar sequence
                const statusTexts = [
                    "Đang xác thực thông tin bảo mật...",
                    "Đang khởi tạo phiên làm việc mã hóa...",
                    "Đang tải dữ liệu trung tâm giám sát IOC...",
                    "Kết nối thành công! Đang chuyển hướng..."
                ];
                let textIndex = 0;
                const subtitleEl = document.querySelector('.intro-subtitle');
                if (subtitleEl) {
                    const textInterval = setInterval(() => {
                        textIndex++;
                        if (textIndex < statusTexts.length) {
                            subtitleEl.style.opacity = 0;
                            setTimeout(() => {
                                subtitleEl.innerText = statusTexts[textIndex];
                                subtitleEl.style.opacity = 1;
                            }, 300);
                        } else {
                            clearInterval(textInterval);
                        }
                    }, 650);
                }

                // 3D Glass Tilt Interaction (Active after card fully revealed)
                const card = document.querySelector('.intro-glass-card');
                if (card) {
                    setTimeout(() => {
                        document.addEventListener('mousemove', (e) => {
                            const xAxis = (window.innerWidth / 2 - e.pageX) / 35;
                            const yAxis = (window.innerHeight / 2 - e.pageY) / 35;
                            card.style.transition = "transform 0.1s ease-out";
                            card.style.transform = `scale(1) rotateY(${xAxis}deg) rotateX(${yAxis}deg)`;
                        });
                    }, 1000);
                }

                setTimeout(() => {
                    intro.classList.add('fade-out');
                    document.body.classList.remove('intro-active');
                    sessionStorage.setItem('adminIntroShown', 'true');
                    
                    setTimeout(() => {
                        intro.remove();
                    }, 800);
                }, 2800);
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>